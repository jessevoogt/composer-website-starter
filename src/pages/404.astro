---
import SiteLayout from '@layouts/SiteLayout.astro'
---

<SiteLayout
  title="404"
  replaceLastAutoBreadcrumbLabel="Page Not Found"
>
  <section class="page-header-section not-found-section">
    <div class="not-found-bg" aria-hidden="true">
      <svg viewBox="0 0 310.598 310.598" xmlns="http://www.w3.org/2000/svg">
        <!-- Caesura (//) — CC0, SVG Repo -->
        <polygon points="239.5,50.299 106,260.299 177.098,260.299 310.598,50.299" fill="currentColor"/>
        <polygon points="204.598,50.299 133.5,50.299 0,260.299 71.098,260.299"   fill="currentColor"/>
      </svg>
    </div>

    <div class="page-header-inner not-found-inner">
      <h1>404</h1>
      <p class="not-found-message">The page you requested isn't in the score.</p>
      <p class="not-found-status">Don't worry, the music doesn't have to end.</p>
      <a href="/" class="immersive-btn immersive-btn-primary not-found-home-link">
        <span class="not-found-home-link-icon" aria-hidden="true">
          <svg
            viewBox="0 0 24 24"
            width="24"
            height="24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.9"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M15.5 5.5L8.5 12L15.5 18.5"></path>
            <path d="M9.25 12H20"></path>
          </svg>
        </span>
        <span class="immersive-btn-label">Da capo</span>
      </a>
    </div>
  </section>
</SiteLayout>

<style>
  .not-found-section {
    position: relative;
    overflow: hidden;
    display: flex;
    min-height: calc(100svh - var(--header-height) - var(--header-breadcrumb-height));
    align-items: center;
  }

  .not-found-bg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    color: var(--ink);
    opacity: 0.045;
  }

  .not-found-bg svg {
    width: min(80%, 44rem);
    height: auto;
  }

  .not-found-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-s);
    text-align: center;
  }

  .not-found-inner h1 {
    font-size: var(--font-size-6);
    margin-bottom: 0;
    line-height: 1;
  }

  .not-found-message {
    font-size: var(--font-size-2);
    color: var(--ink-soft);
    max-width: 40ch;
  }

  .not-found-status {
    font-size: var(--font-size--1);
    color: color-mix(in srgb, var(--ink-soft) 68%, transparent);
    font-weight: 400;
    letter-spacing: 0.03em;
    max-width: 40ch;
  }

  .not-found-home-link {
    gap: 0.52rem;
  }

  .not-found-home-link-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 1.05rem;
    width: 1.05rem;
    height: 1.05rem;
    min-width: 1.05rem;
    min-height: 1.05rem;
    transform-origin: center;
  }

  .not-found-home-link-icon svg {
    width: 1.05rem;
    height: 1.05rem;
    display: block;
  }

  @media (prefers-reduced-motion: no-preference) {
    .not-found-home-link:not(:disabled):hover .not-found-home-link-icon {
      animation: not-found-home-link-icon-bump 240ms ease-out;
    }
  }

  @keyframes not-found-home-link-icon-bump {
    0% {
      transform: translateX(0) scale(1);
    }

    45% {
      transform: translateX(-0.14rem) scale(1.08);
    }

    100% {
      transform: translateX(0) scale(1);
    }
  }
</style>
