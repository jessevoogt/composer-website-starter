---
import type { BrandConfig } from '@/utils/source-config'
import BrandText from '@components/BrandText.astro'
import BrandCustomLogo from '@components/BrandCustomLogo.astro'

interface Props {
  brandConfig: BrandConfig
  composerName: string
  isHomepage?: boolean
}

const { brandConfig, composerName, isHomepage = false } = Astro.props
---

{
  brandConfig.mode === 'custom' ? (
    <BrandCustomLogo composerName={composerName} isHomepage={isHomepage} />
  ) : (
    <BrandText
      firstName={brandConfig.firstName}
      lastName={brandConfig.lastName}
      composerName={composerName}
      isHomepage={isHomepage}
    />
  )
}
