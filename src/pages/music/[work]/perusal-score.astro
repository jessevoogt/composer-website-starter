---
import PerusalLayout from '@layouts/PerusalLayout.astro'
import PerusalScoreViewer from '@components/PerusalScoreViewer.astro'
import Dropdown from '@components/Dropdown.astro'
import { getCollection } from 'astro:content'
import prepareWorks, { type WorkWithImage } from '@/utils/prepareWorks'
import type { RecordingLinkType } from '../../../content.config'
import perusalScores, { perusalScorePageHashes } from '@/utils/perusal-scores'
import { getSiteConfig, getScoreAccessConfig, isScoreGatingActive, getScoreViewerConfig } from '@/utils/source-config'
import pdfScoresManifest from '../../../../api/pdf-scores.json'

const siteConfig = getSiteConfig()
const perusalAccessConfig = getScoreAccessConfig()
const siteGatingActive = isScoreGatingActive()
const perusalViewerConfig = getScoreViewerConfig()

export async function getStaticPaths() {
  const works = await getCollection('works')
  const { works: preparedWorks } = prepareWorks(works)

  return preparedWorks
    .filter((work) => work.data.hasPerusalScore && perusalScores[work.id])
    .map((work) => ({
      params: { work: work.id },
      props: { work },
    }))
}

interface Props {
  work: WorkWithImage
}

const { work } = Astro.props as Props
const pageCount = perusalScores[work.id]
const scorePageHashes = perusalScorePageHashes[work.id] ?? []

// Per-work gating: work override > site-wide default
const workGatingOverride = work.data.scoreOverrides?.viewerGating ?? ''
const isGated =
  workGatingOverride === 'gated' ? true : workGatingOverride === 'ungated' ? false : siteGatingActive

// ── PDF download availability ─────────────────────────────────────────────
type PdfManifestEntry = {
  hasWatermarkedPdf: boolean
  hasOriginalPdf: boolean
  watermarkedGated: boolean
  originalGated: boolean
}

const pdfEntry = (pdfScoresManifest as Record<string, PdfManifestEntry>)[work.id] ?? null

function resolvePdfDownload(entry: PdfManifestEntry | null): {
  hasPdf: boolean
  pdfType: 'original' | 'watermarked' | null
  pdfIsGated: boolean
} {
  if (!entry) return { hasPdf: false, pdfType: null, pdfIsGated: false }
  if (entry.hasOriginalPdf) {
    return { hasPdf: true, pdfType: 'original', pdfIsGated: entry.originalGated }
  }
  if (entry.hasWatermarkedPdf) {
    return { hasPdf: true, pdfType: 'watermarked', pdfIsGated: entry.watermarkedGated }
  }
  return { hasPdf: false, pdfType: null, pdfIsGated: false }
}

const { hasPdf, pdfType, pdfIsGated } = resolvePdfDownload(pdfEntry)

function isRecordingLinkObject(link: RecordingLinkType): link is Exclude<RecordingLinkType, string> {
  return typeof link !== 'string'
}

interface PerusalRecordingTrack {
  src: string
  label: string
  movementIndex: number
  creditLabel: string
  creditType: 'ensemble' | 'performer'
}

function normalizeRecordingSource(link: RecordingLinkType): string {
  if (!isRecordingLinkObject(link)) return ''
  return typeof link.mp3 === 'string' ? link.mp3.trim() : ''
}

function normalizeRecordingLabel(link: RecordingLinkType): string {
  if (!isRecordingLinkObject(link)) return ''
  return typeof link.label === 'string' ? link.label.trim() : ''
}

function getRecordingCredit(
  recording: WorkWithImage['data']['recordings'][number],
): { label: string; type: 'ensemble' | 'performer' } {
  const ensemble = recording.ensemble?.trim() ?? ''
  if (ensemble) return { label: ensemble, type: 'ensemble' }

  const performers = recording.performers.map((performer) => performer.trim()).filter(Boolean)
  return { label: performers.join(', '), type: 'performer' }
}

function getFirstRecordingTrack(nextWork: WorkWithImage): PerusalRecordingTrack | null {
  for (const recording of nextWork.data.recordings) {
    for (const link of recording.links) {
      const src = normalizeRecordingSource(link)
      if (!src) continue
      const credit = getRecordingCredit(recording)
      return {
        src,
        label: normalizeRecordingLabel(link),
        movementIndex: 0,
        creditLabel: credit.label,
        creditType: credit.type,
      }
    }
  }
  return null
}

function getPerusalRecordingTracks(nextWork: WorkWithImage): PerusalRecordingTrack[] {
  const hasMultiMovementRecording = nextWork.data.recordings.some(
    (recording) => recording.links.filter((link) => isRecordingLinkObject(link)).length > 1,
  )

  if (!hasMultiMovementRecording) {
    const firstTrack = getFirstRecordingTrack(nextWork)
    return firstTrack ? [firstTrack] : []
  }

  const movementTracks = new Map<number, PerusalRecordingTrack>()

  for (const recording of nextWork.data.recordings) {
    let movementIndex = 0
    for (const link of recording.links) {
      if (!isRecordingLinkObject(link)) continue

      const src = normalizeRecordingSource(link)
      if (src && !movementTracks.has(movementIndex)) {
        const credit = getRecordingCredit(recording)
        movementTracks.set(movementIndex, {
          src,
          label: normalizeRecordingLabel(link),
          movementIndex,
          creditLabel: credit.label,
          creditType: credit.type,
        })
      }

      movementIndex += 1
    }
  }

  if (movementTracks.size > 0) {
    return [...movementTracks.entries()]
      .sort(([left], [right]) => left - right)
      .map(([, track]) => track)
  }

  const firstTrack = getFirstRecordingTrack(nextWork)
  return firstTrack ? [firstTrack] : []
}

const perusalRecordingTracks = getPerusalRecordingTracks(work)
const perusalRecordingSrc = perusalRecordingTracks[0]?.src ?? null
const showPerusalAudioPlayer = perusalViewerConfig.showAudioPlayer && !!perusalRecordingSrc
const perusalRecordingTracksJson = JSON.stringify(perusalRecordingTracks)
const hasMultiplePerusalTracks = perusalRecordingTracks.length > 1
const perusalViewModeOptions: { value: string; label: string; icon: 'single-page' | 'double-page' }[] =
  perusalViewerConfig.defaultViewMode === 'single'
    ? [
        { value: 'single', label: 'Single page', icon: 'single-page' },
        { value: 'spreads', label: 'Spreads', icon: 'double-page' },
      ]
    : [
        { value: 'spreads', label: 'Spreads', icon: 'double-page' },
        { value: 'single', label: 'Single page', icon: 'single-page' },
      ]
const perusalPageJumpOptions = Array.from({ length: pageCount }, (_, index) => ({
  value: `${index + 1}`,
  label: `Page ${index + 1}`,
  shortLabel: `${index + 1}`,
}))
---

<PerusalLayout
  title={`${work.data.title} — Perusal Score`}
  description={`View the perusal score for ${work.data.title} by ${work.data.composer || siteConfig.composerName}.`}
  url={`/music/${work.id}/perusal-score/`}
  skipTargetId="perusal-score-viewer"
  pageContentClass="perusal-score-main"
  bodyClass="perusal-score-body"
>
  <section
    class="perusal-score-page"
    data-perusal-page
    data-perusal-work-id={work.id}
    data-perusal-work-title={work.data.title}
    data-perusal-has-multiple-tracks={hasMultiplePerusalTracks ? 'true' : 'false'}
    data-perusal-recording-src={showPerusalAudioPlayer ? (perusalRecordingSrc ?? undefined) : undefined}
    data-perusal-reveal-state="loading"
    data-perusal-gating-enabled={isGated ? 'true' : 'false'}
    data-perusal-flip-enabled={perusalViewerConfig.flipAnimationEnabled ? 'true' : 'false'}
    data-perusal-api-endpoint={(isGated || hasPdf) && siteConfig.apiEndpoint ? siteConfig.apiEndpoint : undefined}
    data-perusal-token-secret={isGated ? perusalAccessConfig.tokenSecret : undefined}
    data-perusal-pdf-type={hasPdf ? pdfType : undefined}
    data-perusal-pdf-gated={hasPdf ? (pdfIsGated ? 'true' : 'false') : undefined}
  >
    <style is:inline>
      /* Critical compact-header visibility rules to prevent first-paint flicker before runtime JS sync. */
      @media (orientation: portrait) {
        [data-perusal-page] .perusal-score-topbar {
          grid-template-columns: auto 1fr auto;
        }

        [data-perusal-page] .perusal-score-seek,
        [data-perusal-page] .perusal-topbar-nav .score-nav-label,
        [data-perusal-page] .perusal-score-view-mode-wrap,
        [data-perusal-page] .perusal-score-single-zoom-wrap {
          display: none;
        }

        [data-perusal-page] .perusal-score-back-btn .perusal-score-piece-title {
          position: absolute;
          width: 1px;
          height: 1px;
          padding: 0;
          margin: -1px;
          overflow: hidden;
          clip: rect(0 0 0 0);
          clip-path: inset(50%);
          white-space: nowrap;
          border: 0;
        }
      }

      @media (max-width: 56.25rem) {
        [data-perusal-page][data-perusal-has-multiple-tracks='false'] .perusal-score-topbar {
          grid-template-columns: auto 1fr auto;
        }

        [data-perusal-page][data-perusal-has-multiple-tracks='false'] .perusal-score-seek,
        [data-perusal-page][data-perusal-has-multiple-tracks='false'] .perusal-topbar-nav .score-nav-label {
          display: none;
        }

        [data-perusal-page][data-perusal-has-multiple-tracks='false']
          .perusal-score-back-btn
          .perusal-score-piece-title {
          position: absolute;
          width: 1px;
          height: 1px;
          padding: 0;
          margin: -1px;
          overflow: hidden;
          clip: rect(0 0 0 0);
          clip-path: inset(50%);
          white-space: nowrap;
          border: 0;
        }
      }

      @media (max-width: 68.75rem) {
        [data-perusal-page][data-perusal-has-multiple-tracks='true'] .perusal-score-topbar {
          grid-template-columns: auto 1fr auto;
        }

        [data-perusal-page][data-perusal-has-multiple-tracks='true'] .perusal-score-seek,
        [data-perusal-page][data-perusal-has-multiple-tracks='true'] .perusal-topbar-nav .score-nav-label {
          display: none;
        }

        [data-perusal-page][data-perusal-has-multiple-tracks='true']
          .perusal-score-back-btn
          .perusal-score-piece-title {
          position: absolute;
          width: 1px;
          height: 1px;
          padding: 0;
          margin: -1px;
          overflow: hidden;
          clip: rect(0 0 0 0);
          clip-path: inset(50%);
          white-space: nowrap;
          border: 0;
        }
      }

      @media (pointer: coarse) {
        [data-perusal-page] .perusal-score-single-zoom-wrap {
          display: none;
        }
      }

      /* Perusal score gating: hide the score viewer when gated and locked or not yet checked */
      [data-perusal-page][data-perusal-gating-enabled='true']:not([data-perusal-gate-state]) .perusal-score-viewer-area,
      [data-perusal-page][data-perusal-gating-enabled='true'][data-perusal-gate-state='locked'] .perusal-score-viewer-area {
        visibility: hidden;
        pointer-events: none;
      }

      [data-perusal-page][data-perusal-gating-enabled='true']:not([data-perusal-gate-state]) .perusal-score-topbar,
      [data-perusal-page][data-perusal-gating-enabled='true'][data-perusal-gate-state='locked'] .perusal-score-topbar {
        opacity: 0.3;
        pointer-events: none;
      }
    </style>
    <script is:inline>
      (() => {
        const script = document.currentScript
        const page = script?.closest('[data-perusal-page]')
        if (!(page instanceof HTMLElement)) return

        page.dataset.perusalRevealEnabled = 'true'
        page.setAttribute('aria-busy', 'true')

        let hasRevealed = false
        let readyRequested = false
        let progressTimerId = 0
        let progressTotal = 0
        let reportedLoaded = 0
        let simulatedLoaded = 0
        let displayedLoaded = 0
        let lastSimulationStepAt = 0

        const clearProgressTimer = () => {
          if (!progressTimerId) return
          window.clearInterval(progressTimerId)
          progressTimerId = 0
        }

        const renderProgressMessage = () => {
          if (progressTotal <= 0) {
            setLoadingMessage('Preparing score viewer...')
            return
          }

          const safeDisplayed = Math.min(progressTotal, Math.max(1, displayedLoaded))
          setLoadingMessage(`Loading score pages ${safeDisplayed} of ${progressTotal}...`)
        }

        const advanceDisplayedProgress = () => {
          if (progressTotal <= 0) return false
          const targetLoaded = Math.min(progressTotal, Math.max(1, simulatedLoaded, reportedLoaded))
          if (displayedLoaded >= targetLoaded) return false
          displayedLoaded = Math.min(progressTotal, displayedLoaded + 1)
          renderProgressMessage()
          return true
        }

        const startProgressTimer = () => {
          if (progressTimerId || progressTotal <= 0) return

          if (!lastSimulationStepAt) {
            lastSimulationStepAt = Date.now()
          }

          progressTimerId = window.setInterval(() => {
            if (hasRevealed || progressTotal <= 0) {
              clearProgressTimer()
              return
            }

            const now = Date.now()
            const simulationCap = Math.max(1, progressTotal - 1)
            if (simulatedLoaded < simulationCap && now - lastSimulationStepAt >= 900) {
              simulatedLoaded += 1
              lastSimulationStepAt = now
            }

            const didAdvance = advanceDisplayedProgress()

            if (!didAdvance && reportedLoaded >= progressTotal && displayedLoaded >= progressTotal) {
              clearProgressTimer()
            }
          }, 120)
        }

        const setLoadingMessage = (message) => {
          const progressText = page.querySelector('[data-perusal-loading-progress]')
          if (progressText instanceof HTMLElement) {
            progressText.textContent = message
          }
        }

        const onLoadingProgress = (event) => {
          if (!(event instanceof CustomEvent)) return
          if (!(event.target instanceof Node) || !page.contains(event.target)) return

          const detail = event.detail
          const loaded = Number(detail?.loaded)
          const total = Number(detail?.total)
          const timedOut = detail?.timedOut === true

          if (timedOut) {
            clearProgressTimer()
            setLoadingMessage('Loading is taking longer than expected. Showing available pages.')
            return
          }

          if (!Number.isFinite(total) || total <= 0) {
            clearProgressTimer()
            setLoadingMessage('Preparing score viewer...')
            return
          }

          const safeTotal = Math.max(1, Math.floor(total))
          if (safeTotal !== progressTotal) {
            progressTotal = safeTotal
            reportedLoaded = 0
            simulatedLoaded = 1
            displayedLoaded = 1
            lastSimulationStepAt = Date.now()
            renderProgressMessage()
          }

          const safeLoaded = Number.isFinite(loaded) ? Math.min(Math.max(Math.floor(loaded), 0), safeTotal) : 0
          reportedLoaded = Math.max(reportedLoaded, safeLoaded)

          if (reportedLoaded >= progressTotal && displayedLoaded >= progressTotal) {
            clearProgressTimer()
          } else {
            startProgressTimer()
          }

          if (!advanceDisplayedProgress() && displayedLoaded <= 0 && progressTotal > 0) {
            displayedLoaded = 1
            renderProgressMessage()
          }
        }

        const onViewerReady = (event) => {
          if (!(event.target instanceof Node) || !page.contains(event.target)) return
          if (readyRequested) return
          readyRequested = true

          clearProgressTimer()

          const finishReveal = () => {
            if (hasRevealed) return
            setLoadingMessage('Finalizing score viewer...')
            window.setTimeout(() => {
              reveal()
            }, 160)
          }

          if (progressTotal > 0 && displayedLoaded < progressTotal) {
            reportedLoaded = Math.max(reportedLoaded, progressTotal)
            simulatedLoaded = Math.max(simulatedLoaded, progressTotal)

            const catchUpAndReveal = () => {
              if (hasRevealed) return
              const advanced = advanceDisplayedProgress()
              if (advanced && displayedLoaded < progressTotal) {
                window.setTimeout(catchUpAndReveal, 90)
                return
              }
              finishReveal()
            }

            catchUpAndReveal()
            return
          }

          finishReveal()
        }

        const reveal = () => {
          if (hasRevealed) return
          hasRevealed = true
          clearProgressTimer()
          page.dataset.perusalRevealState = 'ready'
          page.setAttribute('aria-busy', 'false')
          window.clearTimeout(timeoutId)
          document.removeEventListener('perusal-score-loading-progress', onLoadingProgress)
          document.removeEventListener('perusal-score-viewer-ready', onViewerReady)
        }

        const timeoutId = window.setTimeout(() => {
          setLoadingMessage('Loading timed out after 30 seconds. Showing available pages.')
          reveal()
        }, 30000)

        document.addEventListener('perusal-score-loading-progress', onLoadingProgress)
        document.addEventListener('perusal-score-viewer-ready', onViewerReady)
        document.addEventListener(
          'astro:before-swap',
          () => {
            reveal()
          },
          { once: true },
        )
      })()
    </script>
    <h1 class="sr-only">{work.data.title} — Perusal Score</h1>

    <div class="perusal-score-topbar" data-perusal-topbar>
      <div class="perusal-score-topbar-start">
        <a
          href={`/music/${work.id}/`}
          data-astro-reload
          class="perusal-score-topbar-btn perusal-score-back-btn"
          aria-label={`Back to ${work.data.title}`}
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            class="perusal-score-topbar-icon perusal-score-back-arrow"
          >
            <path d="M5 12h13"></path>
            <path d="m13 6 6 6-6 6"></path>
          </svg>
          <span class="perusal-score-piece-title">{work.data.title}</span>
        </a>

        {pageCount > 1 && (
          <div class="perusal-score-view-mode-wrap">
            <Dropdown
              id={`perusal-view-mode-${work.id}`}
              label="Score view mode"
              options={perusalViewModeOptions}
              value={perusalViewerConfig.defaultViewMode}
              class="perusal-score-view-mode-dropdown"
              buttonClass="perusal-score-view-mode-trigger"
              menuClass="perusal-score-view-mode-menu"
              optionClass="perusal-score-view-mode-option"
              align="start"
              data-perusal-view-mode
            />
          </div>
        )}

        {pageCount > 1 && (
          <div class="perusal-score-single-zoom-wrap" data-perusal-single-zoom-wrap hidden>
            <button
              type="button"
              class="perusal-score-topbar-btn perusal-score-icon-btn perusal-score-single-zoom-btn"
              data-perusal-single-zoom-btn
              aria-label={`Score zoom for ${work.data.title}`}
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.85"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                class="perusal-score-topbar-icon"
              >
                <circle cx="10.5" cy="10.5" r="6"></circle>
                <path d="m15.1 15.1 5.1 5.1"></path>
                <path d="M10.5 7.9v5.2"></path>
                <path d="M7.9 10.5h5.2"></path>
              </svg>
              <span class="sr-only">Score zoom</span>
            </button>
            <div class="perusal-score-single-zoom-panel">
              <label class="sr-only" for={`perusal-single-zoom-${work.id}`}>
                Score zoom for {work.data.title}
              </label>
              <input
                id={`perusal-single-zoom-${work.id}`}
                class="perusal-score-single-zoom"
                type="range"
                min="40"
                max="300"
                step="1"
                value="100"
                data-perusal-single-zoom
                aria-label={`Score zoom for ${work.data.title}`}
              />
            </div>
          </div>
        )}
      </div>

      <div class="perusal-score-topbar-center">
        <div class="score-nav perusal-topbar-nav" data-score-nav hidden>
          <button
            type="button"
            class="score-nav-btn score-nav-prev"
            data-score-prev
            aria-label="Previous page"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="score-nav-icon"
            >
              <path d="m15 6-6 6 6 6"></path>
            </svg>
            <span class="score-nav-label">Prev</span>
          </button>
          <Dropdown
            id={`perusal-page-jump-${work.id}`}
            label="Jump to page"
            options={perusalPageJumpOptions}
            value="1"
            align="start"
            class="score-page-indicator perusal-score-page-jump"
            buttonClass="perusal-score-page-jump-trigger"
            menuClass="perusal-score-page-jump-menu"
            optionClass="perusal-score-page-jump-option"
            data-score-page-indicator
            data-perusal-page-jump
            aria-live="polite"
          />
          <span class="sr-only score-page-indicator-sr" data-score-page-indicator-sr>
            Page 1 of {pageCount}
          </span>
          <button
            type="button"
            class="score-nav-btn score-nav-next"
            data-score-next
            aria-label="Next page"
          >
            <span class="score-nav-label">Next</span>
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="score-nav-icon"
            >
              <path d="m9 6 6 6-6 6"></path>
            </svg>
          </button>
        </div>
      </div>

      <div class="perusal-score-topbar-end">
        <div class="perusal-score-audio-group" data-perusal-audio-ui hidden={!showPerusalAudioPlayer}>
          <div class="perusal-score-transport-group">
            <button
              type="button"
              class="perusal-score-topbar-btn perusal-score-icon-btn perusal-score-track-btn perusal-score-track-prev-btn perusal-score-audio-control"
              data-perusal-track-prev
              aria-label="Restart current movement or go to previous movement"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                class="perusal-score-topbar-icon"
              >
                <path d="M6.5 5.5V18.5"></path>
                <path d="M17.5 6.5L8.8 12L17.5 17.5V6.5Z" fill="currentColor" stroke="none"></path>
              </svg>
              <span class="sr-only perusal-score-track-prev-label">Previous movement or restart</span>
            </button>

            <button
              type="button"
              class="perusal-score-topbar-btn perusal-score-icon-btn perusal-score-listen-btn perusal-score-audio-control"
              data-perusal-playpause
              aria-label={`Play recording of ${work.data.title}`}
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                class="perusal-score-topbar-icon"
              >
                <path class="icon-play" d="M8.8 7.4L17 12L8.8 16.6V7.4Z" fill="currentColor" stroke="none"></path>
                <path class="icon-pause" d="M9.4 7.4V16.6M14.6 7.4V16.6"></path>
              </svg>
              <span class="sr-only perusal-score-listen-label">Play</span>
            </button>

            <button
              type="button"
              class="perusal-score-topbar-btn perusal-score-icon-btn perusal-score-track-btn perusal-score-track-next-btn perusal-score-audio-control"
              data-perusal-track-next
              aria-label="Next movement recording"
              hidden={!hasMultiplePerusalTracks}
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                class="perusal-score-topbar-icon"
              >
                <path d="M6.5 5.5V18.5"></path>
                <path d="M17.5 6.5L8.8 12L17.5 17.5V6.5Z" fill="currentColor" stroke="none"></path>
              </svg>
              <span class="sr-only perusal-score-track-next-label">Next movement</span>
            </button>
          </div>

          <div
            class="perusal-score-track-info-wrap perusal-score-audio-control"
            data-perusal-track-info
            hidden={!showPerusalAudioPlayer}
          >
            <button
              type="button"
              class="perusal-score-topbar-btn perusal-score-icon-btn perusal-score-track-info-btn"
              data-perusal-track-info-btn
              aria-label="Current movement details"
              aria-describedby={`perusal-track-info-popover-${work.id}`}
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.9"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                class="perusal-score-topbar-icon"
              >
                <circle cx="12" cy="12" r="8.8"></circle>
                <path d="M12 11.2v5"></path>
                <path d="M12 7.8h.01"></path>
              </svg>
              <span class="sr-only">Current movement details</span>
            </button>
            <div
              id={`perusal-track-info-popover-${work.id}`}
              class="perusal-score-track-info-popover"
              data-perusal-track-info-popover
              role="tooltip"
            >
              <p class="perusal-score-track-info-title" data-perusal-track-info-title></p>
              <p class="perusal-score-track-info-performer" data-perusal-track-info-performer hidden></p>
            </div>
          </div>

          <label class="sr-only" for={`perusal-seek-${work.id}`}>Seek recording of {work.data.title}</label>
          <input
            id={`perusal-seek-${work.id}`}
            type="range"
            min="0"
            max="100"
            step="0.1"
            value="0"
            class="featured-seek perusal-score-seek perusal-score-audio-control"
            data-perusal-seek
            aria-label={`Seek recording of ${work.data.title}`}
          />

          <div class="perusal-score-volume-control">
            <button
              type="button"
              class="perusal-score-topbar-btn perusal-score-icon-btn perusal-score-mute-btn perusal-score-audio-control"
              data-perusal-mute
              aria-label="Mute recording"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                class="perusal-score-topbar-icon"
              >
                <path d="M4.5 10.1h4L13.7 6v12l-5.2-4.1h-4z"></path>
                <path class="icon-sound-on" d="M16.6 9.1a4.4 4.4 0 0 1 0 5.8"></path>
                <path class="icon-sound-on" d="M18.8 7.1a7.1 7.1 0 0 1 0 9.8"></path>
                <path class="icon-sound-off" d="M16.2 9.2l4.2 5.6"></path>
                <path class="icon-sound-off" d="M20.4 9.2l-4.2 5.6"></path>
              </svg>
              <span class="sr-only perusal-score-mute-label">Mute</span>
            </button>
            <div class="perusal-score-volume-panel">
              <label class="sr-only" for={`perusal-volume-${work.id}`}>Recording volume for {work.data.title}</label>
              <input
                id={`perusal-volume-${work.id}`}
                class="perusal-score-volume perusal-score-audio-control"
                type="range"
                min="0"
                max="100"
                step="1"
                value="100"
                data-perusal-volume
                aria-label={`Recording volume for ${work.data.title}`}
              />
            </div>
          </div>
        </div>

        <button
          type="button"
          class="perusal-score-topbar-btn perusal-score-icon-btn perusal-score-fullscreen-btn"
          data-perusal-fullscreen
          aria-label="Enter fullscreen"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            class="perusal-score-topbar-icon"
          >
            <g class="icon-fullscreen-enter">
              <path d="M8 3H5a2 2 0 0 0-2 2v3"></path>
              <path d="M21 8V5a2 2 0 0 0-2-2h-3"></path>
              <path d="M3 16v3a2 2 0 0 0 2 2h3"></path>
              <path d="M16 21h3a2 2 0 0 0 2-2v-3"></path>
            </g>
            <g class="icon-fullscreen-exit">
              <path d="M8 3v3a2 2 0 0 1-2 2H3"></path>
              <path d="M21 8h-3a2 2 0 0 1-2-2V3"></path>
              <path d="M3 16h3a2 2 0 0 0 2 2v3"></path>
              <path d="M16 21v-3a2 2 0 0 0 2-2h3"></path>
            </g>
          </svg>
          <span class="sr-only perusal-score-fullscreen-label">Fullscreen</span>
        </button>

        {hasPdf && (
          <a
            href="#"
            class="immersive-btn immersive-btn-orange perusal-pdf-download-btn"
            data-perusal-pdf-download
            hidden
            download
            aria-label="Download PDF of this score"
            rel="noopener"
          >
            <span class="immersive-btn-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
              </svg>
            </span>
            <span class="immersive-btn-label perusal-pdf-download-label">PDF</span>
          </a>
        )}
      </div>
    </div>

    <div class="perusal-score-mobile-scrubber" data-perusal-mobile-scrubber hidden={!showPerusalAudioPlayer}>
      <label class="sr-only" for={`perusal-mobile-seek-${work.id}`}>Seek recording of {work.data.title}</label>
      <input
        id={`perusal-mobile-seek-${work.id}`}
        type="range"
        min="0"
        max="100"
        step="0.1"
        value="0"
        class="featured-seek perusal-score-mobile-seek perusal-score-audio-control"
        data-perusal-mobile-seek
        aria-label={`Seek recording of ${work.data.title}`}
      />
    </div>

    <div
      id="perusal-score-viewer"
      class="perusal-score-viewer-area"
      data-perusal-viewer-area
      tabindex="-1"
      aria-label={`Perusal score viewer for ${work.data.title}`}
    >
      <div class="perusal-score-loading" data-perusal-loading role="status" aria-live="polite" aria-atomic="true">
        <p class="perusal-score-loading-title">Loading score...</p>
        <p class="perusal-score-loading-progress" data-perusal-loading-progress>
          Preparing pages {pageCount > 0 ? 1 : 0} of {pageCount}...
        </p>
      </div>
      {pageCount ? (
        <PerusalScoreViewer
          title={work.data.title}
          slug={work.id}
          pageCount={pageCount}
          pageHashes={scorePageHashes}
          hideBuiltinNav={true}
          hasPdf={hasPdf}
        />
      ) : null}
    </div>

    <script is:inline type="application/json" data-perusal-recording-tracks set:html={perusalRecordingTracksJson} />
    <audio data-perusal-audio preload="metadata" aria-hidden="true"></audio>
  </section>


  <Fragment slot="body-scripts">
    <script src="../../../scripts/cross-tab-audio.ts"></script>
    {isGated && <script src="../../../scripts/perusal-gate.ts"></script>}
  </Fragment>
</PerusalLayout>

<script>
  type PerusalViewMode = 'auto' | 'spreads' | 'single'
  type PerusalRecordingTrack = {
    src: string
    label: string
    movementIndex: number
    creditLabel: string
    creditType: 'ensemble' | 'performer'
  }

  let teardownPerusalPage: (() => void) | null = null

  function syncSliderProgress(slider: HTMLInputElement): void {
    const max = Number.parseFloat(slider.max)
    const value = Number.parseFloat(slider.value)
    const progress =
      Number.isFinite(max) && max > 0 && Number.isFinite(value)
        ? Math.min(Math.max((value / max) * 100, 0), 100)
        : 0
    slider.style.setProperty('--seek-progress', `${progress}%`)
  }

  function normalizePerusalViewMode(value: string | null | undefined): PerusalViewMode {
    if (value === 'spreads' || value === 'single') return value
    return 'spreads'
  }

  function parsePerusalRecordingTracks(page: HTMLElement): PerusalRecordingTrack[] {
    const tracksScript = page.querySelector<HTMLScriptElement>('[data-perusal-recording-tracks]')
    const serializedTracks = tracksScript?.textContent?.trim() ?? ''
    if (!serializedTracks) return []

    let parsedTracks: unknown
    try {
      parsedTracks = JSON.parse(serializedTracks)
    } catch {
      return []
    }

    if (!Array.isArray(parsedTracks)) return []

    return parsedTracks.flatMap((candidate, index) => {
      if (!candidate || typeof candidate !== 'object') return []

      const track = candidate as {
        src?: unknown
        label?: unknown
        movementIndex?: unknown
        creditLabel?: unknown
        creditType?: unknown
      }
      const src = typeof track.src === 'string' ? track.src.trim() : ''
      if (!src) return []

      const label = typeof track.label === 'string' ? track.label.trim() : ''
      const creditLabel = typeof track.creditLabel === 'string' ? track.creditLabel.trim() : ''
      const creditType = track.creditType === 'ensemble' ? 'ensemble' : 'performer'
      const rawMovementIndex =
        typeof track.movementIndex === 'number'
          ? track.movementIndex
          : Number.parseInt(String(track.movementIndex ?? ''), 10)
      const movementIndex =
        Number.isFinite(rawMovementIndex) && rawMovementIndex >= 0 ? Math.floor(rawMovementIndex) : index

      return [{ src, label, movementIndex, creditLabel, creditType }]
    })
  }

  function initPerusalPage(): void {
    teardownPerusalPage?.()

    const page = document.querySelector<HTMLElement>('[data-perusal-page]')
    if (!page) return

    const playPauseBtn = page.querySelector<HTMLButtonElement>('[data-perusal-playpause]')
    const playPauseLabel = page.querySelector<HTMLElement>('.perusal-score-listen-label')
    const seekInput = page.querySelector<HTMLInputElement>('[data-perusal-seek]')
    const mobileSeekInput = page.querySelector<HTMLInputElement>('[data-perusal-mobile-seek]')
    const muteBtn = page.querySelector<HTMLButtonElement>('[data-perusal-mute]')
    const volumeInput = page.querySelector<HTMLInputElement>('[data-perusal-volume]')
    const muteLabel = page.querySelector<HTMLElement>('.perusal-score-mute-label')
    const fullscreenBtn = page.querySelector<HTMLButtonElement>('[data-perusal-fullscreen]')
    const fullscreenLabel = page.querySelector<HTMLElement>('.perusal-score-fullscreen-label')
    const viewerArea = page.querySelector<HTMLElement>('[data-perusal-viewer-area]')
    const scoreViewer = page.querySelector<HTMLElement>('[data-score-viewer]')
    const viewModeControl = page.querySelector<HTMLElement>('[data-perusal-view-mode]')
    const zoomWrap = page.querySelector<HTMLElement>('[data-perusal-single-zoom-wrap]')
    const zoomInput = page.querySelector<HTMLInputElement>('[data-perusal-single-zoom]')
    const prevNavBtn = page.querySelector<HTMLButtonElement>('[data-score-prev]')
    const nextNavBtn = page.querySelector<HTMLButtonElement>('[data-score-next]')
    const prevTrackBtn = page.querySelector<HTMLButtonElement>('[data-perusal-track-prev]')
    const nextTrackBtn = page.querySelector<HTMLButtonElement>('[data-perusal-track-next]')
    const trackInfoWrap = page.querySelector<HTMLElement>('[data-perusal-track-info]')
    const trackInfoBtn = page.querySelector<HTMLButtonElement>('[data-perusal-track-info-btn]')
    const trackInfoTitle = page.querySelector<HTMLElement>('[data-perusal-track-info-title]')
    const trackInfoPerformer = page.querySelector<HTMLElement>('[data-perusal-track-info-performer]')
    const audioUi = page.querySelector<HTMLElement>('[data-perusal-audio-ui]')
    const mobileScrubber = page.querySelector<HTMLElement>('[data-perusal-mobile-scrubber]')
    const audio = page.querySelector<HTMLAudioElement>('[data-perusal-audio]')
    const pdfDownloadBtn = page.querySelector<HTMLAnchorElement>('[data-perusal-pdf-download]')
    const recordingSrc = page.dataset.perusalRecordingSrc?.trim() ?? ''
    let recordingTracks = parsePerusalRecordingTracks(page)
    if (recordingTracks.length === 0 && recordingSrc) {
      recordingTracks = [{ src: recordingSrc, label: '', movementIndex: 0, creditLabel: '', creditType: 'performer' }]
    }
    const workTitle = page.dataset.perusalWorkTitle ?? 'this work'

    if (
      !playPauseBtn ||
      !seekInput ||
      !muteBtn ||
      !volumeInput ||
      !fullscreenBtn ||
      !audio
    ) {
      return
    }

    // ── PDF download button ──────────────────────────────────────────────────
    const pdfType = page.dataset.perusalPdfType ?? null
    const pdfIsGated = page.dataset.perusalPdfGated === 'true'
    const pdfApiEndpoint = page.dataset.perusalApiEndpoint ?? ''
    const pdfWorkId = page.dataset.perusalWorkId ?? ''
    let pdfGateListener: (() => void) | null = null

    function showPdfButton(): void {
      if (!pdfDownloadBtn || !pdfType || !pdfApiEndpoint) return

      let downloadUrl: string

      if (pdfIsGated) {
        const storedToken = (() => {
          try {
            return localStorage.getItem(`perusal_gate:${pdfWorkId}`)
          } catch {
            return null
          }
        })()
        if (!storedToken) return
        downloadUrl = `${pdfApiEndpoint}/download-score?token=${encodeURIComponent(storedToken)}&type=${pdfType}`
      } else {
        downloadUrl = `${pdfApiEndpoint}/download-score?work=${encodeURIComponent(pdfWorkId)}&type=${pdfType}`
      }

      pdfDownloadBtn.href = downloadUrl
      pdfDownloadBtn.hidden = false
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          if (pdfDownloadBtn) pdfDownloadBtn.dataset.perusalPdfVisible = 'true'
        })
      })
    }

    if (pdfType) {
      const pageIsGated = page.dataset.perusalGatingEnabled === 'true'

      if (!pageIsGated) {
        showPdfButton()
      } else {
        // If already unlocked, show immediately
        if (page.dataset.perusalGateState === 'unlocked') {
          showPdfButton()
        } else {
          const onGateRevealed = (): void => {
            showPdfButton()
          }
          document.addEventListener('perusal-gate-revealed', onGateRevealed, { once: true })
          pdfGateListener = () => {
            document.removeEventListener('perusal-gate-revealed', onGateRevealed)
          }
        }
      }
    }

    let hasRecording = false
    let isSeeking = false
    let activeSeekInput: HTMLInputElement | null = null
    let activeRecordingTrackIndex = 0
    let recordingInitToken = 0
    let lastNonZeroVolume = Math.min(Math.max(audio.volume, 0), 1) || 1
    const seekInputs: HTMLInputElement[] = [seekInput, mobileSeekInput].filter(
      (input): input is HTMLInputElement => !!input,
    )
    const compactWidthViewportDefault = window.matchMedia('(max-width: 56.25rem)')
    const compactWidthViewportMultiMovement = window.matchMedia('(max-width: 68.75rem)')
    const portraitViewport = window.matchMedia('(orientation: portrait)')
    const coarsePointerViewport = window.matchMedia('(pointer: coarse)')
    let compactControlsFrame = 0
    let zoomFitHeightPx = 0
    let currentZoomFactor = 1.0
    let zoomFrame = 0
    let layoutObserver: MutationObserver | null = null
    let isPanning = false
    let panStartX = 0
    let panStartY = 0
    let panScrollLeft = 0
    let panScrollTop = 0
    // Track the booklet element we have pan listeners on (may change across flip↔single cycles)
    let panBooklet: HTMLElement | null = null
    // Cancellation token: incremented by exitSingleZoomMode to cancel any in-flight enterSingleZoomMode rAFs
    let enterZoomToken = 0
    // Swipe-to-navigate state (touch-only, single-page mode)
    let swipeBooklet: HTMLElement | null = null
    let swipeTouchStartX = 0
    let swipeTouchStartY = 0
    let swipeTouchId: number | null = null

    const usesMultiMovementCompactBreakpoint = (): boolean => recordingTracks.length > 1
    const isCompactControls = (): boolean =>
      (usesMultiMovementCompactBreakpoint()
        ? compactWidthViewportMultiMovement.matches
        : compactWidthViewportDefault.matches) || portraitViewport.matches
    // Portrait only: viewer forces auto mode, user has no meaningful mode choice
    const isAutoModeOnly = (): boolean => portraitViewport.matches
    // Zoom requires a precise pointer and a landscape layout
    const canUseZoom = (): boolean => !portraitViewport.matches && !coarsePointerViewport.matches

    const syncCompactControls = (): void => {
      const compact = isCompactControls()
      page.dataset.perusalCompactControls = compact ? 'true' : 'false'
      if (!compact) {
        page.dataset.perusalMobileScrubber = 'false'
      }
    }

    const getActiveRecordingTrack = (): PerusalRecordingTrack | null =>
      recordingTracks[activeRecordingTrackIndex] ?? null

    const getTrackLabel = (track: PerusalRecordingTrack | null): string => {
      if (!track) return workTitle
      if (track.label) return track.label
      if (recordingTracks.length > 1) return `Movement ${track.movementIndex + 1}`
      return workTitle
    }

    const getTrackContextLabel = (track: PerusalRecordingTrack | null): string => {
      if (!track) return workTitle
      const trackLabel = getTrackLabel(track)
      if (trackLabel === workTitle) return workTitle
      return `${workTitle} — ${trackLabel}`
    }

    const getTrackCreditLabel = (track: PerusalRecordingTrack | null): string => track?.creditLabel?.trim() ?? ''
    const getTrackCreditType = (track: PerusalRecordingTrack | null): 'ensemble' | 'performer' =>
      track?.creditType === 'ensemble' ? 'ensemble' : 'performer'

    const syncTrackInfoUi = (): void => {
      const shouldShowTrackInfo = hasRecording
      if (trackInfoWrap) {
        trackInfoWrap.hidden = !shouldShowTrackInfo
      }

      if (!shouldShowTrackInfo) {
        if (trackInfoTitle) trackInfoTitle.textContent = ''
        if (trackInfoPerformer) {
          trackInfoPerformer.textContent = ''
          trackInfoPerformer.hidden = true
        }
        if (trackInfoBtn) {
          trackInfoBtn.setAttribute('aria-label', 'Current movement details unavailable')
        }
        return
      }

      const activeTrack = getActiveRecordingTrack()
      const movementLabel = getTrackLabel(activeTrack)
      const creditLabel = getTrackCreditLabel(activeTrack)
      const creditType = getTrackCreditType(activeTrack)

      if (trackInfoTitle) {
        trackInfoTitle.textContent = movementLabel
      }

      if (trackInfoPerformer) {
        if (creditLabel) {
          trackInfoPerformer.textContent = `${creditType === 'ensemble' ? 'Ensemble' : 'Performer'}: ${creditLabel}`
          trackInfoPerformer.hidden = false
        } else {
          trackInfoPerformer.textContent = ''
          trackInfoPerformer.hidden = true
        }
      }

      if (trackInfoBtn) {
        trackInfoBtn.setAttribute(
          'aria-label',
          creditLabel
            ? `Current movement details: ${movementLabel}, ${creditType === 'ensemble' ? 'ensemble' : 'performer'} ${creditLabel}`
            : `Current movement details: ${movementLabel}`,
        )
      }
    }

    const syncTrackNavigationUi = (): void => {
      const hasNextTrackNavigation = hasRecording && recordingTracks.length > 1
      const previousTrack = hasRecording ? (recordingTracks[activeRecordingTrackIndex - 1] ?? null) : null
      const nextTrack = hasNextTrackNavigation ? (recordingTracks[activeRecordingTrackIndex + 1] ?? null) : null
      const canGoToPreviousTrack = !!previousTrack && audio.currentTime <= 2
      const isPlaying = !audio.paused && !audio.ended
      const disablePreviousRestartAtTrackStart =
        hasRecording && activeRecordingTrackIndex === 0 && audio.currentTime <= 0.01 && !isPlaying

      if (prevTrackBtn) {
        prevTrackBtn.hidden = !hasRecording
        prevTrackBtn.disabled = !hasRecording || disablePreviousRestartAtTrackStart
        prevTrackBtn.setAttribute(
          'aria-label',
          disablePreviousRestartAtTrackStart
            ? 'At the beginning of the first movement'
            : canGoToPreviousTrack && previousTrack
            ? `Previous movement recording: ${getTrackLabel(previousTrack)}`
            : `Restart recording of ${getTrackContextLabel(getActiveRecordingTrack())}`,
        )
      }

      if (nextTrackBtn) {
        nextTrackBtn.hidden = !hasNextTrackNavigation
        nextTrackBtn.disabled = !nextTrack
        nextTrackBtn.setAttribute(
          'aria-label',
          nextTrack ? `Next movement recording: ${getTrackLabel(nextTrack)}` : 'No next movement recording',
        )
      }

      syncTrackInfoUi()
    }

    const setActiveRecordingTrack = async (nextIndex: number, shouldPlay: boolean): Promise<void> => {
      if (nextIndex < 0 || nextIndex >= recordingTracks.length) return
      const nextTrack = recordingTracks[nextIndex]
      if (!nextTrack) return

      activeRecordingTrackIndex = nextIndex
      audio.pause()
      audio.src = nextTrack.src
      audio.currentTime = 0
      audio.load()
      syncAudioUi()

      if (!shouldPlay) return

      try {
        await audio.play()
      } catch {
        // Browsers can block playback without a valid user gesture.
      } finally {
        syncAudioUi()
      }
    }

    const applyNoRecordingState = (): void => {
      hasRecording = false
      activeRecordingTrackIndex = 0
      audio.pause()
      audio.removeAttribute('src')
      audio.currentTime = 0
      playPauseBtn.disabled = true
      seekInputs.forEach((input) => {
        input.disabled = true
      })
      muteBtn.disabled = true
      volumeInput.disabled = true
      audioUi?.setAttribute('hidden', '')
      mobileScrubber?.setAttribute('hidden', '')
      page.dataset.perusalMobileScrubber = 'false'
      playPauseBtn.setAttribute('aria-label', `No recording available for ${workTitle}`)
      if (playPauseLabel) {
        playPauseLabel.textContent = 'No Audio'
      }
      syncTrackNavigationUi()
    }

    const audioSourceExists = async (src: string): Promise<boolean> => {
      const normalizedSrc = src.trim()
      if (!normalizedSrc) return false

      try {
        const response = await fetch(normalizedSrc, { method: 'HEAD', cache: 'no-store' })
        return response.ok
      } catch {
        return false
      }
    }

    const initializeRecording = async (): Promise<void> => {
      const token = ++recordingInitToken

      if (recordingTracks.length === 0) {
        if (token !== recordingInitToken) return
        applyNoRecordingState()
        syncAudioUi()
        return
      }

      const availableTracks: PerusalRecordingTrack[] = []
      for (const track of recordingTracks) {
        if (!track.src) continue
        const exists = await audioSourceExists(track.src)
        if (token !== recordingInitToken) return
        if (exists) {
          availableTracks.push(track)
        }
      }

      if (token !== recordingInitToken) return
      if (availableTracks.length === 0) {
        applyNoRecordingState()
        syncAudioUi()
        return
      }

      recordingTracks = availableTracks
      activeRecordingTrackIndex = 0
      hasRecording = true
      audioUi?.removeAttribute('hidden')
      mobileScrubber?.removeAttribute('hidden')
      page.dataset.perusalMobileScrubber = 'false'
      playPauseBtn.disabled = false
      muteBtn.disabled = false
      volumeInput.disabled = false
      await setActiveRecordingTrack(activeRecordingTrackIndex, false)
      if (token !== recordingInitToken) return
      syncAudioUi()
    }

    const syncAudioUi = (): void => {
      if (!hasRecording) {
        playPauseBtn.setAttribute('data-playing', 'false')
        playPauseBtn.setAttribute('aria-label', `No recording available for ${workTitle}`)
        muteBtn.setAttribute('data-muted', 'false')
        muteBtn.setAttribute('aria-label', 'No recording available')
        volumeInput.disabled = true
        volumeInput.value = '0'
        seekInputs.forEach((input) => {
          input.disabled = true
          syncSliderProgress(input)
        })
        syncTrackNavigationUi()
        return
      }

      const activeTrack = getActiveRecordingTrack()
      const activeTrackContextLabel = getTrackContextLabel(activeTrack)
      const duration = Number.isFinite(audio.duration) ? audio.duration : 0
      const currentTime = Number.isFinite(audio.currentTime) ? audio.currentTime : 0
      const volume = Math.min(Math.max(audio.volume, 0), 1)
      const isPlaying = !audio.paused && !audio.ended
      const isMuted = audio.muted || volume <= 0

      if (volume > 0) {
        lastNonZeroVolume = volume
      }

      if (!isSeeking) {
        seekInputs.forEach((input) => {
          if (input === activeSeekInput) return
          input.max = duration > 0 ? `${duration}` : '100'
          input.value = duration > 0 ? `${Math.min(currentTime, duration)}` : '0'
        })
      }

      seekInputs.forEach((input) => {
        input.disabled = duration <= 0
        syncSliderProgress(input)
      })

      const volumePercent = Math.round((isMuted ? 0 : volume) * 100)
      volumeInput.disabled = false
      volumeInput.value = `${volumePercent}`
      volumeInput.style.setProperty('--volume-progress', `${volumePercent}%`)

      playPauseBtn.setAttribute('data-playing', String(isPlaying))
      playPauseBtn.setAttribute(
        'aria-label',
        `${isPlaying ? 'Pause' : 'Play'} recording of ${activeTrackContextLabel}`,
      )
      if (playPauseLabel) {
        playPauseLabel.textContent = isPlaying ? 'Pause' : 'Play'
      }

      muteBtn.setAttribute('data-muted', String(isMuted))
      muteBtn.setAttribute('aria-label', isMuted ? 'Unmute recording' : 'Mute recording')
      if (muteLabel) {
        muteLabel.textContent = isMuted ? 'Unmute' : 'Mute'
      }
      syncTrackNavigationUi()
    }

    const onPlayPauseClick = async (): Promise<void> => {
      if (!hasRecording) return

      try {
        if (audio.paused || audio.ended) {
          await audio.play()
        } else {
          audio.pause()
        }
      } catch {
        // Browsers can block playback without a valid user gesture.
      } finally {
        syncAudioUi()
      }
    }

    const onMuteClick = (): void => {
      if (!hasRecording) return
      const currentlyMuted = audio.muted || audio.volume <= 0
      if (currentlyMuted) {
        audio.volume = lastNonZeroVolume > 0 ? lastNonZeroVolume : 1
        audio.muted = false
      } else {
        if (audio.volume > 0) {
          lastNonZeroVolume = audio.volume
        }
        audio.muted = true
      }
      syncAudioUi()
    }

    const rewindActiveTrack = (): void => {
      if (!hasRecording) return
      const wasPlaying = !audio.paused && !audio.ended
      audio.currentTime = 0
      if (wasPlaying) {
        audio.play().catch(() => {})
      }
      syncAudioUi()
    }

    const onTrackPrevClick = (): void => {
      if (!hasRecording) return

      if (activeRecordingTrackIndex === 0 || audio.currentTime > 2) {
        rewindActiveTrack()
        return
      }

      const shouldPlay = !audio.paused && !audio.ended
      void setActiveRecordingTrack(activeRecordingTrackIndex - 1, shouldPlay)
    }

    const onTrackNextClick = (): void => {
      if (!hasRecording || recordingTracks.length <= 1) return
      const nextIndex = activeRecordingTrackIndex + 1
      if (nextIndex >= recordingTracks.length) return
      const shouldPlay = !audio.paused && !audio.ended
      void setActiveRecordingTrack(nextIndex, shouldPlay)
    }

    const onVolumeInput = (): void => {
      if (!hasRecording) return
      const nextValue = Number.parseFloat(volumeInput.value)
      if (!Number.isFinite(nextValue)) return

      const volume = Math.min(Math.max(nextValue, 0), 100) / 100
      audio.volume = volume
      if (volume > 0) {
        lastNonZeroVolume = volume
        audio.muted = false
      } else {
        audio.muted = true
      }
      syncAudioUi()
    }

    const onSeekStart = (event: Event): void => {
      isSeeking = true
      activeSeekInput = event.currentTarget instanceof HTMLInputElement ? event.currentTarget : null
    }

    const onSeekInput = (event?: Event): void => {
      if (!hasRecording) return
      const duration = Number.isFinite(audio.duration) ? audio.duration : 0
      const sourceInput =
        event?.currentTarget instanceof HTMLInputElement
          ? event.currentTarget
          : activeSeekInput instanceof HTMLInputElement
            ? activeSeekInput
            : seekInput
      const value = Number.parseFloat(sourceInput.value)
      if (duration > 0 && Number.isFinite(value)) {
        const boundedValue = Math.min(Math.max(value, 0), duration)
        audio.currentTime = boundedValue
        seekInputs.forEach((input) => {
          if (input === sourceInput) return
          input.max = `${duration}`
          input.value = `${boundedValue}`
          syncSliderProgress(input)
        })
      }
      syncAudioUi()
    }

    const onSeekEnd = (event?: Event): void => {
      onSeekInput(event)
      isSeeking = false
      activeSeekInput = null
    }

    const hideMobileScrubber = (): void => {
      if (page.dataset.perusalMobileScrubber !== 'true') return
      page.dataset.perusalMobileScrubber = 'false'
    }

    const revealMobileScrubber = (): void => {
      if (!hasRecording) return
      if (mobileScrubber?.hasAttribute('hidden')) return
      if (page.dataset.perusalCompactControls !== 'true') return
      page.dataset.perusalMobileScrubber = 'true'
    }

    const onDocumentPointerDown = (): void => {
      if (page.dataset.perusalCompactControls !== 'true') return
      if (page.dataset.perusalMobileScrubber !== 'true') return
      if (!audio.paused) return
      hideMobileScrubber()
    }

    const syncFullscreenState = (): void => {
      const isFullscreen = !!document.fullscreenElement
      fullscreenBtn.setAttribute('aria-label', isFullscreen ? 'Exit fullscreen' : 'Enter fullscreen')
      fullscreenBtn.setAttribute('data-fullscreen', String(isFullscreen))
      if (fullscreenLabel) {
        fullscreenLabel.textContent = isFullscreen ? 'Exit' : 'Fullscreen'
      }
    }

    const onFullscreenClick = (): void => {
      if (!document.fullscreenEnabled) return
      if (!document.fullscreenElement) {
        const fullscreenTarget =
          page.dataset.perusalCompactControls === 'true' && viewerArea instanceof HTMLElement ? viewerArea : page
        fullscreenTarget.requestFullscreen().catch(() => {})
      } else {
        document.exitFullscreen().catch(() => {})
      }
    }

    const scheduleCompactControlsSync = (): void => {
      if (compactControlsFrame) {
        window.cancelAnimationFrame(compactControlsFrame)
      }
      compactControlsFrame = window.requestAnimationFrame(() => {
        compactControlsFrame = 0
        syncCompactControls()
        dispatchViewModeChange()
        syncTrackInfoUi()
      })
    }

    const onAudioEnded = (): void => {
      audio.currentTime = 0
      syncAudioUi()
    }

    const onAudioError = (): void => {
      applyNoRecordingState()
      syncAudioUi()
    }

    const onPlayPauseButtonClick = (): void => {
      revealMobileScrubber()
      void onPlayPauseClick()
    }

    const getSelectedViewMode = (): PerusalViewMode => {
      if (!viewModeControl) return 'spreads'
      if (viewModeControl instanceof HTMLSelectElement) {
        return normalizePerusalViewMode(viewModeControl.value)
      }
      return normalizePerusalViewMode(viewModeControl.dataset.dropdownValue)
    }

    const dispatchViewModeChange = (userInitiated = false): void => {
      // In portrait the viewer forces auto mode; landscape screens honour the dropdown selection
      const mode = isAutoModeOnly() ? 'auto' : getSelectedViewMode()
      document.dispatchEvent(
        new CustomEvent('perusal-score-view-mode-change', {
          detail: { mode, viewer: scoreViewer, userInitiated },
        }),
      )
    }

    const onViewModeSelectChange = (event?: Event): void => {
      if (event instanceof CustomEvent && viewModeControl && event.target !== viewModeControl) return
      dispatchViewModeChange(true)
    }

    // ── Single-page zoom & pan ─────────────────────────────────────────

    // Always query the live booklet — page-flip may replace the element across mode switches
    const getLiveBooklet = (): HTMLElement | null =>
      scoreViewer?.querySelector<HTMLElement>('[data-score-booklet]') ?? null

    const computeFitHeight = (): number => {
      if (!scoreViewer) return 0
      const liveBooklet = getLiveBooklet()
      if (!liveBooklet) return 0
      const s = window.getComputedStyle(liveBooklet)
      const pt = parseFloat(s.paddingTop) || 0
      const pb = parseFloat(s.paddingBottom) || 0
      const available = liveBooklet.clientHeight - pt - pb
      return available > 0 ? available : 0
    }

    const applyZoom = (factor: number): void => {
      if (!scoreViewer) return
      const clamped = Math.min(Math.max(factor, 0.4), 3.0)
      currentZoomFactor = clamped
      const heightPx = zoomFitHeightPx * clamped
      if (heightPx > 0) {
        scoreViewer.style.setProperty('--single-zoom-height', `${heightPx}px`)
        scoreViewer.setAttribute('data-single-zoom', '')
      } else {
        scoreViewer.style.removeProperty('--single-zoom-height')
        scoreViewer.removeAttribute('data-single-zoom')
      }
    }

    const resetZoom = (): void => {
      currentZoomFactor = 1.0
      zoomFitHeightPx = 0
      if (zoomInput) zoomInput.value = '100'
      if (scoreViewer) {
        scoreViewer.style.removeProperty('--single-zoom-height')
        scoreViewer.removeAttribute('data-single-zoom')
      }
    }

    const detachPanListeners = (): void => {
      if (!panBooklet) return
      panBooklet.removeEventListener('pointerdown', onBookletPointerDown)
      panBooklet.removeEventListener('pointermove', onBookletPointerMove)
      panBooklet.removeEventListener('pointerup', onBookletPointerUp)
      panBooklet.removeEventListener('pointercancel', onBookletPointerUp)
      panBooklet = null
    }

    const attachPanListeners = (booklet: HTMLElement): void => {
      if (panBooklet === booklet) return
      detachPanListeners()
      panBooklet = booklet
      panBooklet.addEventListener('pointerdown', onBookletPointerDown)
      panBooklet.addEventListener('pointermove', onBookletPointerMove)
      panBooklet.addEventListener('pointerup', onBookletPointerUp)
      panBooklet.addEventListener('pointercancel', onBookletPointerUp)
    }

    // Swipe-to-navigate (touch-only, single-page mode)
    const onSwipeTouchStart = (e: TouchEvent): void => {
      if (e.touches.length !== 1) { swipeTouchId = null; return }
      if (scoreViewer?.hasAttribute('data-single-zoom')) return // mouse-zoom active — panning handled elsewhere
      if ((window.visualViewport?.scale ?? 1) > 1) return // browser pinch-zoomed — let native pan work
      const touch = e.touches[0]
      swipeTouchStartX = touch.clientX
      swipeTouchStartY = touch.clientY
      swipeTouchId = touch.identifier
    }

    const onSwipeTouchEnd = (e: TouchEvent): void => {
      if (swipeTouchId === null) return
      if (scoreViewer?.hasAttribute('data-single-zoom')) { swipeTouchId = null; return }
      const changedTouch = Array.from(e.changedTouches).find((t) => t.identifier === swipeTouchId)
      swipeTouchId = null
      if (!changedTouch) return
      const deltaX = changedTouch.clientX - swipeTouchStartX
      const deltaY = changedTouch.clientY - swipeTouchStartY
      // Require at least 40px horizontal with 1.5× horizontal-to-vertical ratio
      if (Math.abs(deltaX) < 40 || Math.abs(deltaX) <= Math.abs(deltaY) * 1.5) return
      if (deltaX < 0) {
        nextNavBtn?.click()
      } else {
        prevNavBtn?.click()
      }
    }

    const detachSwipeListeners = (): void => {
      if (!swipeBooklet) return
      swipeBooklet.removeEventListener('touchstart', onSwipeTouchStart)
      swipeBooklet.removeEventListener('touchend', onSwipeTouchEnd)
      swipeBooklet.removeEventListener('touchcancel', onSwipeTouchEnd)
      swipeBooklet = null
      swipeTouchId = null
    }

    const attachSwipeListeners = (booklet: HTMLElement): void => {
      if (swipeBooklet === booklet) return
      detachSwipeListeners()
      swipeBooklet = booklet
      swipeBooklet.addEventListener('touchstart', onSwipeTouchStart, { passive: true })
      swipeBooklet.addEventListener('touchend', onSwipeTouchEnd)
      swipeBooklet.addEventListener('touchcancel', onSwipeTouchEnd)
    }

    const enterSingleZoomMode = (): void => {
      // Zoom requires a mouse/trackpad and landscape layout; touch users have native pinch-to-zoom
      if (!canUseZoom()) return
      // Double rAF: ensures layout has fully settled after data-score-layout change.
      // Token guards against the race where exitSingleZoomMode runs before the rAFs fire.
      const token = ++enterZoomToken
      window.requestAnimationFrame(() => {
        window.requestAnimationFrame(() => {
          if (token !== enterZoomToken) return
          const liveBooklet = getLiveBooklet()
          zoomFitHeightPx = computeFitHeight()
          currentZoomFactor = 1.0
          if (zoomInput) zoomInput.value = '100'
          applyZoom(1.0)
          if (zoomWrap) zoomWrap.hidden = false
          if (liveBooklet) attachPanListeners(liveBooklet)
        })
      })
    }

    const exitSingleZoomMode = (): void => {
      enterZoomToken++ // cancel any in-flight enterSingleZoomMode rAF chain
      if (zoomWrap) zoomWrap.hidden = true
      resetZoom()
      detachPanListeners()
      isPanning = false
      if (scoreViewer) scoreViewer.removeAttribute('data-panning')
    }

    const onZoomInput = (): void => {
      if (!zoomInput) return
      const raw = Number.parseFloat(zoomInput.value)
      if (Number.isFinite(raw)) applyZoom(raw / 100)
    }

    const scheduleZoomRecompute = (): void => {
      if (zoomFrame) window.cancelAnimationFrame(zoomFrame)
      zoomFrame = window.requestAnimationFrame(() => {
        zoomFrame = 0
        if (!scoreViewer || scoreViewer.dataset.scoreLayout !== 'single') return
        if (!canUseZoom()) {
          // Portrait or coarse pointer — clear any active zoom
          if (zoomFitHeightPx > 0) exitSingleZoomMode()
          return
        }
        if (zoomFitHeightPx <= 0) {
          // Zoom became available (e.g. rotated to landscape, or switched to mouse) while in single layout
          enterSingleZoomMode()
          return
        }
        const newFit = computeFitHeight()
        if (newFit <= 0) return
        zoomFitHeightPx = newFit
        applyZoom(currentZoomFactor)
      })
    }

    const onNavClick = (): void => {
      if (!scoreViewer || scoreViewer.dataset.scoreLayout !== 'single') return
      window.requestAnimationFrame(() => {
        const liveBooklet = getLiveBooklet()
        if (liveBooklet) {
          liveBooklet.scrollLeft = 0
          liveBooklet.scrollTop = 0
        }
      })
    }

    const onBookletPointerDown = (e: PointerEvent): void => {
      if (!scoreViewer || scoreViewer.dataset.scoreLayout !== 'single') return
      if (e.pointerType === 'touch' || !panBooklet) return
      isPanning = true
      panStartX = e.clientX
      panStartY = e.clientY
      panScrollLeft = panBooklet.scrollLeft
      panScrollTop = panBooklet.scrollTop
      scoreViewer.setAttribute('data-panning', '')
      panBooklet.setPointerCapture(e.pointerId)
    }

    const onBookletPointerMove = (e: PointerEvent): void => {
      if (!isPanning || !panBooklet) return
      panBooklet.scrollLeft = panScrollLeft - (e.clientX - panStartX)
      panBooklet.scrollTop = panScrollTop - (e.clientY - panStartY)
    }

    const onBookletPointerUp = (): void => {
      if (!isPanning) return
      isPanning = false
      if (scoreViewer) scoreViewer.removeAttribute('data-panning')
    }

    const setupLayoutObserver = (): void => {
      if (!scoreViewer) return
      layoutObserver = new MutationObserver(() => {
        const layout = scoreViewer.dataset.scoreLayout
        if (layout === 'single') {
          enterSingleZoomMode()
          const liveBooklet = getLiveBooklet()
          if (liveBooklet) attachSwipeListeners(liveBooklet)
        } else {
          exitSingleZoomMode()
          detachSwipeListeners()
        }
      })
      layoutObserver.observe(scoreViewer, { attributes: true, attributeFilter: ['data-score-layout'] })
      if (scoreViewer.dataset.scoreLayout === 'single') {
        enterSingleZoomMode()
        const liveBooklet = getLiveBooklet()
        if (liveBooklet) attachSwipeListeners(liveBooklet)
      }
    }

    void initializeRecording()

    syncCompactControls()
    page.dataset.perusalMobileScrubber = 'false'

    if (!document.fullscreenEnabled) {
      fullscreenBtn.hidden = true
    }

    playPauseBtn.addEventListener('click', onPlayPauseButtonClick)
    if (prevTrackBtn) prevTrackBtn.addEventListener('click', onTrackPrevClick)
    if (nextTrackBtn) nextTrackBtn.addEventListener('click', onTrackNextClick)
    muteBtn.addEventListener('click', onMuteClick)
    volumeInput.addEventListener('input', onVolumeInput)
    volumeInput.addEventListener('change', onVolumeInput)
    seekInputs.forEach((input) => {
      input.addEventListener('pointerdown', onSeekStart)
      input.addEventListener('mousedown', onSeekStart)
      input.addEventListener('touchstart', onSeekStart, { passive: true })
      input.addEventListener('input', onSeekInput)
      input.addEventListener('change', onSeekEnd)
      input.addEventListener('pointerup', onSeekEnd)
      input.addEventListener('mouseup', onSeekEnd)
      input.addEventListener('keyup', onSeekEnd)
    })
    audio.addEventListener('play', syncAudioUi)
    audio.addEventListener('pause', syncAudioUi)
    audio.addEventListener('timeupdate', syncAudioUi)
    audio.addEventListener('loadedmetadata', syncAudioUi)
    audio.addEventListener('durationchange', syncAudioUi)
    audio.addEventListener('volumechange', syncAudioUi)
    audio.addEventListener('error', onAudioError)
    audio.addEventListener('ended', onAudioEnded)
    fullscreenBtn.addEventListener('click', onFullscreenClick)
    document.addEventListener('fullscreenchange', syncFullscreenState)
    compactWidthViewportDefault.addEventListener('change', scheduleCompactControlsSync)
    compactWidthViewportMultiMovement.addEventListener('change', scheduleCompactControlsSync)
    portraitViewport.addEventListener('change', scheduleCompactControlsSync)
    coarsePointerViewport.addEventListener('change', scheduleCompactControlsSync)
    window.addEventListener('resize', scheduleCompactControlsSync, { passive: true })
    document.addEventListener('pointerdown', onDocumentPointerDown, { passive: true })
    if (viewModeControl) {
      if (viewModeControl instanceof HTMLSelectElement) {
        viewModeControl.value = normalizePerusalViewMode(viewModeControl.value)
        viewModeControl.addEventListener('change', onViewModeSelectChange)
      } else {
        viewModeControl.dataset.dropdownValue = normalizePerusalViewMode(viewModeControl.dataset.dropdownValue)
        viewModeControl.addEventListener('shared-dropdown-change', onViewModeSelectChange)
      }
    }

    if (zoomInput) {
      zoomInput.addEventListener('input', onZoomInput)
      zoomInput.addEventListener('change', onZoomInput)
    }
    // Pan listeners are attached/detached dynamically in enterSingleZoomMode/exitSingleZoomMode
    // because the booklet element may be replaced across flip↔single mode switches
    if (prevNavBtn) prevNavBtn.addEventListener('click', onNavClick)
    if (nextNavBtn) nextNavBtn.addEventListener('click', onNavClick)
    window.addEventListener('resize', scheduleZoomRecompute, { passive: true })

    syncAudioUi()
    syncFullscreenState()
    dispatchViewModeChange()
    setupLayoutObserver()

    teardownPerusalPage = () => {
      pdfGateListener?.()
      playPauseBtn.removeEventListener('click', onPlayPauseButtonClick)
      if (prevTrackBtn) prevTrackBtn.removeEventListener('click', onTrackPrevClick)
      if (nextTrackBtn) nextTrackBtn.removeEventListener('click', onTrackNextClick)
      muteBtn.removeEventListener('click', onMuteClick)
      volumeInput.removeEventListener('input', onVolumeInput)
      volumeInput.removeEventListener('change', onVolumeInput)
      seekInputs.forEach((input) => {
        input.removeEventListener('pointerdown', onSeekStart)
        input.removeEventListener('mousedown', onSeekStart)
        input.removeEventListener('touchstart', onSeekStart)
        input.removeEventListener('input', onSeekInput)
        input.removeEventListener('change', onSeekEnd)
        input.removeEventListener('pointerup', onSeekEnd)
        input.removeEventListener('mouseup', onSeekEnd)
        input.removeEventListener('keyup', onSeekEnd)
      })
      audio.removeEventListener('play', syncAudioUi)
      audio.removeEventListener('pause', syncAudioUi)
      audio.removeEventListener('timeupdate', syncAudioUi)
      audio.removeEventListener('loadedmetadata', syncAudioUi)
      audio.removeEventListener('durationchange', syncAudioUi)
      audio.removeEventListener('volumechange', syncAudioUi)
      audio.removeEventListener('error', onAudioError)
      audio.removeEventListener('ended', onAudioEnded)
      fullscreenBtn.removeEventListener('click', onFullscreenClick)
      document.removeEventListener('fullscreenchange', syncFullscreenState)
      compactWidthViewportDefault.removeEventListener('change', scheduleCompactControlsSync)
      compactWidthViewportMultiMovement.removeEventListener('change', scheduleCompactControlsSync)
      portraitViewport.removeEventListener('change', scheduleCompactControlsSync)
      coarsePointerViewport.removeEventListener('change', scheduleCompactControlsSync)
      window.removeEventListener('resize', scheduleCompactControlsSync)
      document.removeEventListener('pointerdown', onDocumentPointerDown)
      if (viewModeControl) {
        if (viewModeControl instanceof HTMLSelectElement) {
          viewModeControl.removeEventListener('change', onViewModeSelectChange)
        } else {
          viewModeControl.removeEventListener('shared-dropdown-change', onViewModeSelectChange)
        }
      }

      if (compactControlsFrame) {
        window.cancelAnimationFrame(compactControlsFrame)
        compactControlsFrame = 0
      }

      recordingInitToken += 1

      audio.pause()
      audio.currentTime = 0

      if (document.fullscreenElement) {
        document.exitFullscreen().catch(() => {})
      }

      if (zoomInput) {
        zoomInput.removeEventListener('input', onZoomInput)
        zoomInput.removeEventListener('change', onZoomInput)
      }
      detachPanListeners()
      detachSwipeListeners()
      if (prevNavBtn) prevNavBtn.removeEventListener('click', onNavClick)
      if (nextNavBtn) nextNavBtn.removeEventListener('click', onNavClick)
      window.removeEventListener('resize', scheduleZoomRecompute)
      layoutObserver?.disconnect()
      layoutObserver = null
      if (zoomFrame) {
        window.cancelAnimationFrame(zoomFrame)
        zoomFrame = 0
      }
      resetZoom()
      if (zoomWrap) zoomWrap.hidden = true
      isPanning = false
      if (scoreViewer) scoreViewer.removeAttribute('data-panning')
    }
  }

  const startPerusalPage = () => {
    initPerusalPage()
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', startPerusalPage, { once: true })
  } else {
    startPerusalPage()
  }

  document.addEventListener('astro:page-load', startPerusalPage)
  document.addEventListener('astro:before-swap', () => {
    teardownPerusalPage?.()
    teardownPerusalPage = null
  })
</script>

