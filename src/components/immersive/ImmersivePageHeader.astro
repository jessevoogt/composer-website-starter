---
import ImmersiveBreadcrumbs from './ImmersiveBreadcrumbs.astro'
import sanitizeHtml from 'sanitize-html'

interface Props {
  title: string
  subtitle?: string
  subtitleClass?: string
  showBreadcrumbs?: boolean
  customBreadcrumbLabels?: Record<string, string>
  joinLastBreadcrumb?: boolean
  class?: string
}

const {
  title,
  subtitle,
  subtitleClass,
  showBreadcrumbs = false,
  customBreadcrumbLabels,
  joinLastBreadcrumb = false,
  class: className,
} = Astro.props

const formatSegment = (segment: string): string => {
  if (customBreadcrumbLabels?.[segment]) {
    return customBreadcrumbLabels[segment]
  }
  return segment
    .split('-')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ')
}

const sanitizedSubtitle: string = subtitle
  ? sanitizeHtml(subtitle, {
      allowedTags: ['b', 'i', 'em', 'strong', 'a', 'span', 'br'],
      allowedAttributes: {
        a: ['href', 'title', 'target', 'rel'],
        span: ['class'],
      },
      transformTags: {
        a: (tagName, attribs) => {
          const href = attribs.href ?? ''
          const isExternal = /^https?:\/\//i.test(href)
          if (isExternal) {
            return {
              tagName,
              attribs: { ...attribs, target: '_blank', rel: 'nofollow noopener noreferrer' },
            }
          }
          return { tagName, attribs }
        },
      },
    })
  : ''

// Build breadcrumb items
const path = Astro.url.pathname
const segments = path.split('/').filter(Boolean)

type BreadcrumbItem = { href?: string; label: string; currentPage?: boolean }
const breadcrumbItems: BreadcrumbItem[] = []

if (showBreadcrumbs && segments.length > 0) {
  breadcrumbItems.push({ href: '/', label: 'Home' })

  segments.forEach((segment, index) => {
    if (joinLastBreadcrumb && index === segments.length - 1) return

    const url = `/${segments.slice(0, index + 1).join('/')}/`
    const isLast = index === segments.length - 1 || (joinLastBreadcrumb && index === segments.length - 2)

    let formattedName: string
    if (joinLastBreadcrumb && isLast) {
      const prevSegment = segments[segments.length - 2]
      const lastSegment = segments[segments.length - 1]
      formattedName = `${formatSegment(prevSegment)}: ${formatSegment(lastSegment)}`
    } else {
      formattedName = formatSegment(segment)
    }

    breadcrumbItems.push({
      href: isLast ? undefined : url,
      label: formattedName,
      currentPage: isLast,
    })
  })
}
---

<section class:list={['page-header-section', className]}>
  {breadcrumbItems.length > 0 && <ImmersiveBreadcrumbs items={breadcrumbItems} />}
  <div class="page-header-inner">
    <h1>{title}</h1>
    {sanitizedSubtitle && <p class:list={['page-header-subtitle', subtitleClass]} set:html={sanitizedSubtitle} />}
    <slot />
  </div>
</section>
