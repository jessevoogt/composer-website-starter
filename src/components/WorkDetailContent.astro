---
import ImmersivePageHeader from '@components/immersive/ImmersivePageHeader.astro'
import ImmersiveBadge from '@components/immersive/ImmersiveBadge.astro'
import SocialShares from '@components/SocialShares.astro'
import FormattedDate from '@components/FormattedDate.astro'
import RecordingList from '@components/RecordingList.astro'
import ButtonLink from '@components/ui/ButtonLink.astro'
import { render } from 'astro:content'
import type { WorkWithImage } from '@/utils/prepareWorks'
import perusalScores from '@/utils/perusal-scores'
import worksImages from '@/utils/works-images'
import { slugify } from '@/utils/slugify'
import { marked } from 'marked'
import { getSharingConfig } from '@/utils/source-config'

const sharingConfig = getSharingConfig()

interface Props {
  work: WorkWithImage
  /** Where the "View Score" button links. Omit to hide the button. */
  scoreButtonHref?: string
  /** Whether to add data-astro-reload to the score button (true for PerusalLayout targets). */
  scoreButtonReload?: boolean
}

const { work, scoreButtonHref, scoreButtonReload } = Astro.props
const { Content } = await render(work)

const rawDescriptionHtml = await marked.parse(work.data.description)
// Add target/_blank and rel attributes to any external links produced by marked
const descriptionHtml = rawDescriptionHtml.replace(
  /<a\s+href="(https?:\/\/[^"]+)"([^>]*)>/g,
  '<a href="$1"$2 target="_blank" rel="nofollow noopener noreferrer">',
)

function getHostName(url: string) {
  try {
    const parsedUrl = new URL(url)
    return parsedUrl.hostname.replace('www.', '')
  } catch {
    return null
  }
}
function getDefaultSheetMusicTooltip(url: string) {
  const hostName = getHostName(url)
  if (hostName) {
    return `Purchase ${work.data.title} on ${hostName}`
  }
  return `Purchase ${work.data.title}`
}
function getSheetMusicTooltip(sm: (typeof work.data.sheetMusic)[number]) {
  if (typeof sm === 'string') return getDefaultSheetMusicTooltip(sm) || sm
  return sm.tooltip || getDefaultSheetMusicTooltip(sm.url) || sm.url
}
function getSheetMusicLabel(sm: (typeof work.data.sheetMusic)[number]) {
  if (typeof sm === 'string') return getHostName(sm) || sm
  return sm.label || getHostName(sm.url) || sm.url
}
function getSheetMusicAriaLabel(sm: (typeof work.data.sheetMusic)[number]) {
  if (typeof sm === 'string') return getSheetMusicTooltip(sm)
  return sm.label || getSheetMusicTooltip(sm)
}
function getSheetMusicUrl(sm: (typeof work.data.sheetMusic)[number]) {
  if (typeof sm === 'string') {
    return sm
  } else {
    return sm.url
  }
}

import type { InstrumentationType, InstrumentSectionType } from '../content.config'

const tagSlugsForWork = new Set(work.tagSlugs)

function resolveInstrumentLink(label: string) {
  const slug = slugify(label)
  return tagSlugsForWork.has(slug) ? `/music/browse/${slug}/` : undefined
}

interface InstrumentEntry {
  label: string
  href: string | undefined
  note?: string
  details: string[]
}

interface SectionEntry {
  section: string
  instruments: InstrumentEntry[]
}

const instr: InstrumentationType = work.data.categorization.instrumentation
const isGrouped = instr.grouped

function normalizeInstrumentEntry(item: string | { label: string; details?: string[]; note?: string }): InstrumentEntry {
  const label = typeof item === 'string' ? item.trim() : item.label.trim()
  const details = typeof item === 'string' ? [] : (item.details ?? [])
  const note = typeof item === 'string' ? undefined : item.note
  return { label, href: resolveInstrumentLink(label), note, details }
}

const flatEntries: InstrumentEntry[] = isGrouped
  ? []
  : instr.instruments.map((s) => ({ label: s.trim(), href: resolveInstrumentLink(s.trim()), details: [] })).filter((e) => e.label)

const sectionEntries: SectionEntry[] = isGrouped
  ? instr.sections.map((s: InstrumentSectionType) => ({
      section: s.section,
      instruments: s.instruments.map(normalizeInstrumentEntry).filter((e) => e.label),
    }))
  : []

const totalInstrumentCount = isGrouped
  ? sectionEntries.reduce((sum, s) => sum + s.instruments.length, 0)
  : flatEntries.length
const instrumentLabel = instr.label || (isGrouped ? `${totalInstrumentCount} instruments` : undefined)
const tagEntries = work.data.categorization.tags
  .map((value) => value.trim())
  .filter(Boolean)
  .map((label) => {
    const slug = slugify(label)
    return {
      label,
      href: tagSlugsForWork.has(slug) ? `/music/browse/${slug}/` : undefined,
    }
  })
const hasPerusalScore = Boolean(work.data.hasPerusalScore && perusalScores[work.id])

const hasRecordings = Boolean(work.data.recordings && work.data.recordings.length > 0)
const showThumbnailFallback = !hasRecordings && work.data.thumbnail
const resolvedThumbnailSrc = (() => {
  if (!work.data.thumbnail) return ''
  const normalized = work.data.thumbnail.src.toLowerCase()
  const matched = worksImages.find((img) => img.path.toLowerCase() === normalized)
  return matched ? matched.data.src : work.data.thumbnail.src
})()
---

<ImmersivePageHeader title={work.data.title} subtitle={work.data.subtitle} subtitleClass="work-detail-subtitle" class="work-detail-page-header">
  {
    hasPerusalScore && scoreButtonHref ? (
      <ButtonLink
        href={scoreButtonHref}
        variant="primary"
        class="work-detail-score-link"
        reload={scoreButtonReload}
      >
        View Score
        <span slot="icon-right" class="work-detail-score-link-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <ellipse cx="9" cy="17.3" rx="2.9" ry="2.35" fill="currentColor" stroke="none"></ellipse>
            <path d="M11.8 17.3V5.2"></path>
            <path d="M11.8 5.3c2.8 0.35 4.8 2.1 4.8 4.6-1.2-1.1-3-1.5-4.8-1.2"></path>
          </svg>
        </span>
      </ButtonLink>
    ) : null
  }
  <div class="work-header-meta-layout">
    <div class={`work-description-panel${showThumbnailFallback ? ' has-thumbnail' : ''}`}>
      <div class="work-description-text" set:html={descriptionHtml} />
      {showThumbnailFallback ? (
        <figure class="work-thumbnail-figure">
          <img
            src={resolvedThumbnailSrc}
            alt={work.data.thumbnail!.alt}
            loading="lazy"
            decoding="async"
            class="work-thumbnail-image"
          />
        </figure>
      ) : null}
    </div>
    <div class="work-meta-panel">
      <div class="work-meta-panel-scroll">
        <dl class="work-meta-grid">
          {totalInstrumentCount > 0 ? (
            <>
              <dt>Instrumentation:</dt>
              <dd>
                {isGrouped ? (
                  <button
                    type="button"
                    class="instr-modal-trigger"
                    aria-label={`View full instrumentation for ${work.data.title}`}
                    data-instr-modal-open
                  >
                    {instrumentLabel}
                    <svg class="instr-modal-trigger-icon" aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="15 3 21 3 21 9"></polyline>
                      <polyline points="9 21 3 21 3 15"></polyline>
                      <line x1="21" y1="3" x2="14" y2="10"></line>
                      <line x1="3" y1="21" x2="10" y2="14"></line>
                    </svg>
                  </button>
                ) : totalInstrumentCount > 8 ? (
                  <details class="instr-collapse" open>
                    <summary>{instrumentLabel || `${totalInstrumentCount} instruments`}</summary>
                    <ul class="instrumentation-list" role="list">
                      {flatEntries.map((inst) => (
                        <li>{inst.href ? <a href={inst.href}>{inst.label}</a> : inst.label}</li>
                      ))}
                    </ul>
                  </details>
                ) : instrumentLabel ? (
                  <div class="instr-labeled-flat">
                    <span class="instr-flat-label">{instrumentLabel}</span>
                    <ul class="instrumentation-list" role="list">
                      {flatEntries.map((inst) => (
                        <li>{inst.href ? <a href={inst.href}>{inst.label}</a> : inst.label}</li>
                      ))}
                    </ul>
                  </div>
                ) : (
                  <ul class="instrumentation-list" role="list">
                    {flatEntries.map((inst) => (
                      <li>{inst.href ? <a href={inst.href}>{inst.label}</a> : inst.label}</li>
                    ))}
                  </ul>
                )}
              </dd>
            </>
          ) : null}

          {
            work.data.duration ? (
              <>
                <dt>Duration:</dt>
                <dd>{work.data.duration}</dd>
              </>
            ) : null
          }
          {
            work.data.difficulty ? (
              <>
                <dt>Difficulty:</dt>
                <dd>{work.data.difficulty}</dd>
              </>
            ) : null
          }
          {
            work.data.completionDate ? (
              <>
                <dt>Completion date:</dt>
                <dd>
                  <FormattedDate date={work.data.completionDate} />
                </dd>
              </>
            ) : null
          }
          {
            work.data.sheetMusic.length ? (
              <>
                <dt>Sheet Music:</dt>
                <dd style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                  {work.data.sheetMusic.map((sm) => (
                    <a
                      href={getSheetMusicUrl(sm)}
                      target="_blank"
                      rel="noreferrer noopener"
                      title={getSheetMusicTooltip(sm)}
                      aria-label={getSheetMusicAriaLabel(sm)}
                    >
                      {getSheetMusicLabel(sm)}
                    </a>
                  ))}
                </dd>
              </>
            ) : null
          }
          {
            tagEntries.length ? (
              <>
                <dt>Tags:</dt>
                <dd>
                  <ul class="tags-list">
                    {tagEntries.map((tag) => (
                      <li>{tag.href ? <ImmersiveBadge href={tag.href}>{tag.label}</ImmersiveBadge> : <ImmersiveBadge>{tag.label}</ImmersiveBadge>}</li>
                    ))}
                  </ul>
                </dd>
              </>
            ) : null
          }
        </dl>
      </div>
    </div>
  </div>
  {isGrouped && sectionEntries.length > 0 && (
    <dialog
      class="instr-modal"
      id="instr-modal"
      aria-labelledby="instr-modal-title"
      data-instr-modal
    >
      <div class="instr-modal-panel" tabindex="-1" data-instr-modal-panel>
        <button
          type="button"
          class="instr-modal-close"
          data-instr-modal-close
          aria-label="Close instrumentation"
        >
          <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
            <path d="M6 6L18 18"></path>
            <path d="M18 6L6 18"></path>
          </svg>
        </button>
        <h2 id="instr-modal-title" class="instr-modal-heading">
          {instrumentLabel}
        </h2>
        <div class="instr-modal-sections" data-even={sectionEntries.length % 2 === 0 ? '' : undefined}>
          {sectionEntries.map((s) => (
            <div class="instr-modal-section">
              <h3 class="instr-modal-section-name">{s.section}</h3>
              <ul class="instr-modal-list" role="list">
                {s.instruments.map((inst) => (
                  <li>
                    {inst.href ? <a href={inst.href}>{inst.label}</a> : inst.label}
                    {inst.details.length > 0 && (
                      <ul class="instr-modal-details" role="list">
                        {inst.details.map((d) => <li>{d}</li>)}
                      </ul>
                    )}
                    {inst.note ? <span class="instr-note">{inst.note}</span> : null}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </dialog>
  )}
  <script>
    interface InstrModalWindow extends Window {
      __instrModalBound?: boolean
    }
    function initInstrModal(): () => void {
      const modal = document.querySelector<HTMLDialogElement>('[data-instr-modal]')
      const trigger = document.querySelector<HTMLButtonElement>('[data-instr-modal-open]')
      if (!modal || !trigger) return () => {}

      const panel = modal.querySelector<HTMLElement>('[data-instr-modal-panel]')
      const closeBtn = modal.querySelector<HTMLButtonElement>('[data-instr-modal-close]')
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      const closeMs = 180
      let closeTimer = 0
      let openFrame = 0

      function clearTimers(): void {
        if (closeTimer) { window.clearTimeout(closeTimer); closeTimer = 0 }
        if (openFrame) { window.cancelAnimationFrame(openFrame); openFrame = 0 }
      }

      function syncClosed(): void {
        modal!.classList.remove('is-visible', 'is-closing')
      }

      function finishClose(): void {
        clearTimers()
        if (modal!.open) modal!.close()
        syncClosed()
      }

      function closeModal(): void {
        clearTimers()
        if (!modal!.open) { syncClosed(); return }
        if (reducedMotion) { finishClose(); return }
        modal!.classList.remove('is-visible')
        modal!.classList.add('is-closing')
        closeTimer = window.setTimeout(finishClose, closeMs)
      }

      function openModal(): void {
        clearTimers()
        if (!modal!.open) modal!.showModal()
        modal!.classList.remove('is-closing')
        if (reducedMotion) {
          modal!.classList.add('is-visible')
        } else {
          openFrame = requestAnimationFrame(() => {
            openFrame = requestAnimationFrame(() => {
              openFrame = 0
              modal!.classList.add('is-visible')
            })
          })
        }
        panel?.focus()
      }

      const onTrigger = (): void => openModal()
      const onClose = (): void => closeModal()
      const onCancel = (e: Event): void => { e.preventDefault(); closeModal() }
      const onClick = (e: MouseEvent): void => { if (e.target === modal) closeModal() }
      const onDialogClose = (): void => syncClosed()

      trigger.addEventListener('click', onTrigger)
      closeBtn?.addEventListener('click', onClose)
      modal.addEventListener('cancel', onCancel)
      modal.addEventListener('click', onClick)
      modal.addEventListener('close', onDialogClose)

      return () => {
        clearTimers()
        trigger.removeEventListener('click', onTrigger)
        closeBtn?.removeEventListener('click', onClose)
        modal.removeEventListener('cancel', onCancel)
        modal.removeEventListener('click', onClick)
        modal.removeEventListener('close', onDialogClose)
        if (modal.open) modal.close()
        syncClosed()
      }
    }

    const w = window as unknown as InstrModalWindow
    if (!w.__instrModalBound) {
      w.__instrModalBound = true
      document.addEventListener('astro:page-load', () => {
        const teardown = initInstrModal()
        document.addEventListener('astro:before-swap', () => teardown(), { once: true })
      })
    }
  </script>

  {hasRecordings ? (
    <div class="work-detail-recordings-row">
      <RecordingList
        recordings={work.data.recordings!}
        workId={work.id}
        workTitle={work.data.title}
        composer={work.data.composer}
        thumbnail={work.data.thumbnail}
        singleLinkHeadingLevel="h2"
        creditTagLinks={work.creditTagLinks}
      />
    </div>
  ) : null}
</ImmersivePageHeader>
<section class="work-detail-content-section">
  <div class="narrow space-content container">
    <Content />
  </div>
</section>
{!sharingConfig.hidden && (
<section class="work-detail-share-section">
  <div class="narrow space-content container">
    <h2>{sharingConfig.sectionTitle}</h2>
    <p>{sharingConfig.sectionDescription}</p>
    <SocialShares />
  </div>
</section>
)}

<style is:global>
  .page-content-work-detail {
    padding-bottom: 0;
  }

  .work-detail-content-section {
    margin-block: var(--space-xl);
  }

  .work-detail-share-section {
    margin-top: var(--space-xl);
    margin-bottom: 0;
    background: color-mix(in srgb, var(--bg-soft) 86%, var(--surface) 14%);
    padding-block: clamp(1.75rem, 4vw, 2.75rem);
  }

  .work-detail-page-header .page-header-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: start;
    column-gap: var(--space-s);
    row-gap: 0.15rem;
  }

  .work-detail-page-header .page-header-inner > h1 {
    flex: 1 1 18rem;
    min-width: 0;
    margin-bottom: 0;
  }

  .work-detail-page-header .page-header-inner > .page-header-subtitle {
    order: 2;
    flex: 1 1 100%;
    margin-top: 0.5rem;
  }

  .page-header-subtitle.work-detail-subtitle {
    max-width: 72ch;
    color: var(--ink);
    font-size: var(--font-size-1);
    font-weight: 600;
    line-height: 1.3;
  }

  .immersive-btn-primary.work-detail-score-link {
    order: 1;
    flex: 0 0 auto;
    display: inline-flex;
    gap: 0.42rem;
    align-self: flex-start;
    margin-left: auto;
    margin-top: 0.18rem;
    white-space: nowrap;
    background: var(--cta-bg);
    border-color: color-mix(in srgb, var(--cta-bg) 82%, #000);
    color: var(--cta-ink);
  }

  .immersive-btn-primary.work-detail-score-link:not(:disabled):hover,
  .immersive-btn-primary.work-detail-score-link:not(:disabled):focus-visible {
    background: color-mix(in srgb, var(--cta-bg) 86%, #000);
    border-color: color-mix(in srgb, var(--cta-bg) 72%, #000);
    color: var(--cta-ink);
  }

  .immersive-btn-primary.work-detail-score-link:not(:disabled):active {
    background: color-mix(in srgb, var(--cta-bg) 72%, #000);
    border-color: color-mix(in srgb, var(--cta-bg) 65%, #000);
    color: var(--cta-ink);
  }

  /* On the request-score-access page, tone down the button so it doesn't
     compete with the modal dialog overlay for the user's attention. */
  [data-request-score-access-page] .immersive-btn-primary.work-detail-score-link {
    background: transparent;
    border-color: color-mix(in srgb, var(--btn-ghost) 64%, transparent);
    color: var(--btn-ghost);
  }

  [data-request-score-access-page] .immersive-btn-primary.work-detail-score-link:not(:disabled):hover,
  [data-request-score-access-page] .immersive-btn-primary.work-detail-score-link:not(:disabled):focus-visible {
    border-color: var(--ink);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--ink);
  }

  [data-request-score-access-page] .immersive-btn-primary.work-detail-score-link:not(:disabled):active {
    background: color-mix(in srgb, var(--accent) 18%, transparent);
  }

  .work-detail-score-link-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5em;
    height: 1.5em;
    min-width: 1.5em;
    flex: 0 0 auto;
    color: currentColor;
    transform-origin: center;
  }

  .work-detail-score-link-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .work-header-meta-layout {
    order: 3;
    flex: 1 1 100%;
    min-width: 0;
    margin-top: var(--space-s);
    display: grid;
    gap: var(--space-s);
  }

  .work-detail-recordings-row {
    order: 4;
    flex: 1 1 100%;
    min-width: 0;
  }

  .work-description-panel.has-thumbnail {
    display: grid;
    gap: var(--space-s);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface-soft) 50%, transparent);
    padding: var(--space-s);
  }

  .work-thumbnail-figure {
    margin: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .work-thumbnail-image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .work-description-text {
    color: var(--ink-soft);
    font-size: var(--font-size-0);
    line-height: 1.5;
  }

  .page-header-section .work-description-text p {
    margin: 0;
    max-width: 68ch;
  }

  .work-description-text p + p {
    margin-top: 0.75em;
  }

  .work-meta-grid {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.2em 1.5em;
    align-items: start;
    font-size: var(--font-size--1);
    margin: 0;
  }

  .work-meta-grid dt {
    font-weight: 600;
    color: var(--ink);
  }

  .work-meta-grid dd {
    color: var(--ink-soft);
    margin: 0;
  }

  @media (min-width: 64rem), (min-width: 48rem) and (orientation: landscape) {
    .work-detail-page-header .page-header-inner {
      display: grid;
      grid-template-columns: 1fr minmax(0, auto);
      grid-template-rows: auto auto auto 1fr;
      column-gap: var(--space-s);
      row-gap: 0;
      align-items: start;
    }

    .work-detail-page-header .page-header-inner > h1 {
      grid-column: 1;
      grid-row: 1;
    }

    .work-detail-page-header .page-header-inner > .page-header-subtitle {
      grid-column: 1;
      grid-row: 2;
    }

    .immersive-btn-primary.work-detail-score-link {
      grid-column: 1;
      grid-row: 3;
      justify-self: start;
      padding: 0.62rem 1rem;
      margin-left: 0;
      margin-top: var(--space-s);
      align-self: start;
    }

    /* Promote children into the parent grid */
    .work-header-meta-layout {
      display: contents;
    }

    .work-meta-panel {
      grid-column: 2;
      grid-row: 1 / 5;
      align-self: start;
      max-width: min(22rem, 40vw);
      border: 1px solid var(--line);
      border-color: color-mix(in srgb, var(--line) 62%, transparent);
      border-radius: var(--radius-md);
      background: var(--bg-soft);
      background: color-mix(in srgb, var(--bg) 72%, var(--surface) 28%);
      padding: var(--space-s);
    }

    .work-description-panel {
      grid-column: 1 / -1;
      grid-row: 5;
      margin-top: var(--space-s);
      max-height: calc(1.5 * var(--font-size-0) * 6 + 3.75em);
      overflow-y: auto;
    }

    .work-description-panel.has-thumbnail {
      grid-template-columns: minmax(0, 2fr) minmax(0, 3fr);
      align-items: center;
      max-height: none;
    }

    .work-description-panel.has-thumbnail .work-thumbnail-figure {
      grid-column: 1;
      grid-row: 1;
    }

    .work-description-panel.has-thumbnail .work-description-text {
      grid-column: 2;
      grid-row: 1;
      max-width: 32ch;
      max-height: 20rem;
      margin: 0 auto;
      overflow-y: auto;
    }

    .work-meta-panel-scroll {
      max-height: 33vh;
      overflow-y: auto;
    }

    .work-meta-grid {
      max-height: 33vh;
      overflow-y: auto;
      font-size: var(--font-size--2);
    }

    .work-detail-recordings-row {
      grid-column: 1 / -1;
      grid-row: 6;
    }
  }

  /* Remove the extra top margin applied by .space-content > dl > * + *
     for this dl so grid gap controls row spacing and alignment */
  .space-content > dl.work-meta-grid > * + * {
    margin-block-start: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .work-detail-score-link:hover .work-detail-score-link-icon,
    .work-detail-score-link:focus-visible .work-detail-score-link-icon {
      animation: work-detail-score-icon-bump 240ms ease-out;
    }
  }

  @keyframes work-detail-score-icon-bump {
    0% {
      transform: translateY(0) scale(1);
    }

    45% {
      transform: translateY(-0.12rem) scale(1.08);
    }

    100% {
      transform: translateY(0) scale(1);
    }
  }

  @media (max-width: 36rem) {
    .work-detail-page-header .page-header-inner {
