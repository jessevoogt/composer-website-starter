---
import { getSiteConfig, isScoreGatingActive, getWorkDetailPage } from '@/utils/source-config'
import { resolvePageHero } from '@/utils/page-hero'
import PerusalOnlyRedirect from '@components/PerusalOnlyRedirect.astro'
import WorkDetailContent from '@components/WorkDetailContent.astro'
const siteConfig = getSiteConfig()
const isPerusalOnlyMode = siteConfig.perusalScoreOnlyMode
import SiteLayout from '@layouts/SiteLayout.astro'
import { getCollection } from 'astro:content'
import prepareWorks, { type WorkWithImage } from '@/utils/prepareWorks'
import perusalScores from '@/utils/perusal-scores'

export async function getStaticPaths() {
  const works = await getCollection('works')
  const { works: preparedWorks } = prepareWorks(works)

  return preparedWorks.map((work) => {
    return {
      params: { work: work.id },
      props: { work: work },
    }
  })
}

interface Props {
  work: WorkWithImage
}

const { work } = Astro.props

const descriptionMeta = work.data.description
  .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
  .replace(/[*_~`]+/g, '')
  .replace(/\n+/g, ' ')
  .trim()

const hasPerusalScore = Boolean(work.data.hasPerusalScore && perusalScores[work.id])

// Perusal score gating
const siteGatingActive = isScoreGatingActive()
const workGatingOverride = work.data.perusalScoreGated ?? ''
const isWorkGated =
  workGatingOverride === 'gated' ? true : workGatingOverride === 'ungated' ? false : siteGatingActive

// Resolve page hero: per-work hero → global work detail default → none
const workDetailConfig = getWorkDetailPage()
const { pageHero } = resolvePageHero(work.data.preferredHeroId || workDetailConfig.preferredHeroId)
---

{isPerusalOnlyMode ? (
  <PerusalOnlyRedirect />
) : (
<SiteLayout
  title={work.data.title}
  description={descriptionMeta}
  url={`/music/${work.id}/`}
  image={work.data.thumbnail?.src ? `/social/work/${work.id}.png` : undefined}
  imageAlt={
    typeof work.data.thumbnail?.alt === 'string' && work.data.thumbnail.alt.trim().length > 0
      ? work.data.thumbnail.alt
      : `${work.data.title} social preview image`
  }
  pageContentClass="page-content-work-detail"
  customBreadcrumbLabels={{ [work.id]: work.data.title }}
  pageHero={pageHero}
  pageKey="work-detail"
  workSlug={work.id}
  pageDefaultHeroId={workDetailConfig.preferredHeroId}
>
  <WorkDetailContent
    work={work}
    scoreButtonHref={hasPerusalScore
      ? (isWorkGated ? `/music/${work.id}/request-score-access/` : `/music/${work.id}/perusal-score/`)
      : undefined}
    scoreButtonReload={!isWorkGated}
  />
</SiteLayout>
)}
