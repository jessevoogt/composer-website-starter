---
import { getContactPage, getSiteConfig } from '@/utils/source-config'
import Button from '@components/ui/Button.astro'

interface Props {
  idPrefix?: string
  autofocusName?: boolean
}

const { idPrefix = 'immersive', autofocusName = false } = Astro.props
const nameFieldId = `${idPrefix}-name`
const emailFieldId = `${idPrefix}-email`
const messageFieldId = `${idPrefix}-request`
const siteConfig = getSiteConfig()
const apiEndpoint = siteConfig.apiEndpoint
const contactConfig = getContactPage()
const contactWebhookUrl = contactConfig.contactWebhookUrl
const composerEmail = siteConfig.email
---

<form
  class="contact-form"
  action="#"
  method="post"
  data-contact-form
  data-contact-api-endpoint={apiEndpoint || undefined}
  data-contact-webhook-url={contactWebhookUrl || undefined}
  data-composer-email={composerEmail || undefined}
  data-char-counter-enabled={contactConfig.showCharacterCount ? 'true' : undefined}
  data-char-counter-threshold={String(contactConfig.characterCountThreshold)}
  novalidate
>
  {/* Honeypot — hidden from humans, filled by bots */}
  <div class="contact-hp" aria-hidden="true">
    <label for={`${idPrefix}-website`}>Website</label>
    <input type="text" id={`${idPrefix}-website`} name="website" autocomplete="off" tabindex={-1} />
  </div>

  <div class="contact-field">
    <input
      id={nameFieldId}
      name="name"
      type="text"
      autocomplete="name"
      placeholder="What should I call you?"
      maxlength={contactConfig.nameMaxLength}
      required
      autofocus={autofocusName ? true : undefined}
    />
    <label for={nameFieldId}>Name</label>
  </div>

  <div class="contact-field">
    <input
      id={emailFieldId}
      name="email"
      type="email"
      autocomplete="email"
      placeholder="you@domain.com"
      maxlength={254}
      required
    />
    <label for={emailFieldId}>Email</label>
  </div>

  <div class="contact-field contact-field-message">
    <textarea
      id={messageFieldId}
      name="request"
      rows={5}
      placeholder="Enter your message here..."
      maxlength={contactConfig.messageMaxLength}
      required
    ></textarea>
    <label for={messageFieldId}>Message</label>
  </div>

  <Button type="submit" variant="primary" class="contact-submit-btn">
    <span data-contact-submit-label>Send</span>
    <Fragment slot="append">
      <span class="contact-submit-spinner" data-contact-spinner hidden aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="2" stroke-dasharray="40 20" stroke-linecap="round">
            <animateTransform attributeName="transform" type="rotate" from="0 10 10" to="360 10 10" dur="0.8s" repeatCount="indefinite" />
          </circle>
        </svg>
      </span>
      <span class="contact-submit-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4.5 6.5h15a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1h-15a1 1 0 0 1-1-1v-9a1 1 0 0 1 1-1z"></path>
          <path d="m4 7 8 6 8-6"></path>
        </svg>
      </span>
    </Fragment>
  </Button>

  <div class="contact-success" data-contact-success hidden role="status" aria-live="polite">
    <p>Message sent! We will get back to you soon.</p>
  </div>

  <div class="contact-error" data-contact-error hidden role="alert" aria-live="assertive" tabindex="-1">
    <!-- JS populates: error text + retry button + mailto link -->
  </div>
</form>

<style>
  .contact-hp {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  .contact-submit-spinner {
    display: inline-flex;
    align-items: center;
  }

  .contact-success {
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--accent, #97c6de) 15%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent, #97c6de) 40%, transparent);
    color: var(--ink, #ecf2f7);
    font-size: var(--font-size-sm, 0.875rem);
  }

  .contact-success p {
    margin: 0;
  }

  .contact-error {
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, #f87171 15%, transparent);
    border: 1px solid color-mix(in srgb, #f87171 40%, transparent);
    color: #fca5a5;
    font-size: var(--font-size-sm, 0.875rem);
  }

  .contact-error p {
    margin: 0;
  }

  .contact-error:focus {
    outline: none;
  }

  .contact-error-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    font-size: var(--font-size-sm, 0.875rem);
  }

  .contact-error-retry {
    background: none;
    border: 1px solid #f87171;
    border-radius: var(--radius-sm);
    color: #fca5a5;
    padding: 0.35rem 0.75rem;
    font: inherit;
    font-size: var(--font-size-sm, 0.875rem);
    cursor: pointer;
    transition: background-color 150ms ease;
  }

  .contact-error-retry:hover {
    background: color-mix(in srgb, #f87171 15%, transparent);
  }

  .contact-error-retry:focus-visible {
    outline: 2px solid var(--focus-ring-color, #97c6de);
    outline-offset: 2px;
  }

  .contact-error-divider {
    color: var(--ink-soft, #aab8c4);
  }

  .contact-error-mailto {
    color: #fca5a5;
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .contact-error-mailto:hover {
    color: #fecaca;
  }

  .contact-error-mailto:focus-visible {
    outline: 2px solid var(--focus-ring-color, #97c6de);
    outline-offset: 2px;
  }
</style>
