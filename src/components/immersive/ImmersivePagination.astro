---
import ButtonLink from '@components/ui/ButtonLink.astro'

interface Props {
  firstPage: string | null
  previousPage: string | null
  nextPage: string | null
  lastPage: string | null
  currentPage: string
  totalPages: string
  ariaLabel?: string
}

const {
  firstPage,
  previousPage,
  nextPage,
  lastPage,
  currentPage,
  totalPages,
  ariaLabel = 'Pagination',
} = Astro.props
---

<nav aria-label={ariaLabel} class="pagination">
  {
    firstPage ? (
      <ButtonLink href={firstPage} variant="control" aria-label="First page">First</ButtonLink>
    ) : (
      <span class="immersive-btn immersive-btn-control" aria-disabled="true" style="opacity: 0.45; cursor: default;">
        <span class="immersive-btn-label">First</span>
      </span>
    )
  }
  {
    previousPage ? (
      <ButtonLink href={previousPage} variant="control" aria-label="Previous page">Prev</ButtonLink>
    ) : (
      <span class="immersive-btn immersive-btn-control" aria-disabled="true" style="opacity: 0.45; cursor: default;">
        <span class="immersive-btn-label">Prev</span>
      </span>
    )
  }
  <span class="pagination-info" aria-current="page">
    {currentPage} / {totalPages}
  </span>
  {
    nextPage ? (
      <ButtonLink href={nextPage} variant="control" aria-label="Next page">Next</ButtonLink>
    ) : (
      <span class="immersive-btn immersive-btn-control" aria-disabled="true" style="opacity: 0.45; cursor: default;">
        <span class="immersive-btn-label">Next</span>
      </span>
    )
  }
  {
    lastPage ? (
      <ButtonLink href={lastPage} variant="control" aria-label="Last page">Last</ButtonLink>
    ) : (
      <span class="immersive-btn immersive-btn-control" aria-disabled="true" style="opacity: 0.45; cursor: default;">
        <span class="immersive-btn-label">Last</span>
      </span>
    )
  }
</nav>
