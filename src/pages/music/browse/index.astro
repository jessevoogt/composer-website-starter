---
import { getSiteConfig as _checkMode, getMusicBrowsePage } from '@/utils/source-config'
import { resolvePageHero } from '@/utils/page-hero'
import PerusalOnlyRedirect from '@components/PerusalOnlyRedirect.astro'
const isPerusalOnlyMode = _checkMode().perusalScoreOnlyMode
const musicBrowsePage = getMusicBrowsePage()
const { pageHero } = resolvePageHero(musicBrowsePage.preferredHeroId)
import SiteLayout from '@layouts/SiteLayout.astro'
import ImmersivePageHeader from '@components/immersive/ImmersivePageHeader.astro'
import ImmersiveBadge from '@components/immersive/ImmersiveBadge.astro'
import { getCollection } from 'astro:content'
import prepareWorks from '@/utils/prepareWorks'
import { getPerformerCreditKey, getPerformerCreditLabel, normalizeCreditKey } from '@/utils/credit-labels'

interface TagItem {
  label: string
  slug: string
  count: number
}

function normalizeInstrumentation(value: string): string {
  return value.toLowerCase().replace(/^\d+\s*/, '').replace(/\s+/g, ' ').trim()
}

function addWorkToKey(map: Map<string, Set<string>>, key: string, workId: string): void {
  const workIds = map.get(key) ?? new Set<string>()
  workIds.add(workId)
  map.set(key, workIds)
}

function addInstrumentationTerm(termSet: Set<string>, value: string): void {
  if (!value) return
  termSet.add(value)
  if (value.endsWith('s') && value.length > 1) termSet.add(value.slice(0, -1))
  if (value.endsWith('i') && value.length > 1) termSet.add(`${value.slice(0, -1)}o`)
}

function isInstrumentationTag(label: string, instrumentationTerms: Set<string>): boolean {
  const normalized = normalizeInstrumentation(label)
  if (!normalized) return false
  if (instrumentationTerms.has(normalized)) return true
  if (normalized.endsWith('s') && instrumentationTerms.has(normalized.slice(0, -1))) return true
  if (normalized.endsWith('i') && instrumentationTerms.has(`${normalized.slice(0, -1)}o`)) return true
  return false
}

const worksCollection = await getCollection('works')
const { works, uniqueTags } = prepareWorks(worksCollection)

const tagByKey = new Map(uniqueTags.map((tag) => [normalizeCreditKey(tag.label), tag]))
const tagCountBySlug = new Map<string, number>()

for (const work of works) {
  const uniqueSlugsForWork = new Set(work.tagSlugs)
  for (const slug of uniqueSlugsForWork) {
    tagCountBySlug.set(slug, (tagCountBySlug.get(slug) ?? 0) + 1)
  }
}

function toTagItem(label: string): TagItem | null {
  const key = normalizeCreditKey(label)
  const tag = tagByKey.get(key)
  if (!tag) return null
  return {
    label: tag.label,
    slug: tag.slug,
    count: tagCountBySlug.get(tag.slug) ?? 0,
  }
}

function compactTagItems(items: Array<TagItem | null>): TagItem[] {
  return items.filter((item): item is TagItem => item !== null)
}

const performerWorkIdsByKey = new Map<string, Set<string>>()
const performerLabelByKey = new Map<string, string>()
const ensembleWorkIdsByKey = new Map<string, Set<string>>()
const ensembleLabelByKey = new Map<string, string>()
const creditWorkIdsByKey = new Map<string, Set<string>>()
const frontmatterTagKeys = new Set<string>()
const instrumentationTerms = new Set<string>()

for (const work of worksCollection) {
  for (const tag of work.data.categorization.tags) {
    frontmatterTagKeys.add(normalizeCreditKey(tag))
  }

  const instrData = work.data.categorization.instrumentation
  const instrFlat = instrData.grouped
    ? instrData.sections.flatMap((s) => s.instruments.map((i) => (typeof i === 'string' ? i : i.label)))
    : instrData.instruments
  for (const instrument of instrFlat) {
    addInstrumentationTerm(instrumentationTerms, normalizeInstrumentation(instrument))
  }

  for (const recording of work.data.recordings) {
    const ensemble = recording.ensemble?.trim()
    if (ensemble) {
      const key = normalizeCreditKey(ensemble)
      if (!ensembleLabelByKey.has(key)) ensembleLabelByKey.set(key, ensemble)
      addWorkToKey(ensembleWorkIdsByKey, key, work.id)
      addWorkToKey(creditWorkIdsByKey, key, work.id)
    }

    for (const performer of recording.performers) {
      const label = performer.trim()
      if (!label) continue
      const key = getPerformerCreditKey(label)
      if (!performerLabelByKey.has(key)) performerLabelByKey.set(key, getPerformerCreditLabel(label))
      addWorkToKey(performerWorkIdsByKey, key, work.id)
      addWorkToKey(creditWorkIdsByKey, key, work.id)
    }
  }
}

const sharedCreditKeys = new Set(
  [...creditWorkIdsByKey.entries()].filter(([, workIds]) => workIds.size > 1).map(([key]) => key),
)

// If a shared credit appears as both performer and ensemble across recordings,
// classify it as ensemble for display purposes.
const sharedEnsembleKeys = new Set(
  [...sharedCreditKeys].filter((key) => (ensembleWorkIdsByKey.get(key)?.size ?? 0) > 0),
)
const sharedPerformerKeys = new Set(
  [...sharedCreditKeys].filter((key) => !sharedEnsembleKeys.has(key) && (performerWorkIdsByKey.get(key)?.size ?? 0) > 0),
)

const performerTags = compactTagItems(
  [...sharedPerformerKeys].map((key) => toTagItem(performerLabelByKey.get(key) ?? key)),
).sort((a, b) => a.label.localeCompare(b.label))

const ensembleTags = compactTagItems(
  [...sharedEnsembleKeys].map((key) => toTagItem(ensembleLabelByKey.get(key) ?? key)),
).sort((a, b) => a.label.localeCompare(b.label))

const contentTagItems = compactTagItems(
  [...frontmatterTagKeys]
    .filter((key) => !sharedCreditKeys.has(key))
    .map((key) => toTagItem(tagByKey.get(key)?.label ?? key)),
).sort((a, b) => a.label.localeCompare(b.label))

const instrumentationTags = contentTagItems.filter((tag) => isInstrumentationTag(tag.label, instrumentationTerms))
const styleAndOtherTags = contentTagItems.filter((tag) => !isInstrumentationTag(tag.label, instrumentationTerms))

const usedSlugs = new Set(
  [...performerTags, ...ensembleTags, ...instrumentationTags, ...styleAndOtherTags].map((tag) => tag.slug),
)
const uncategorizedTags = uniqueTags
  .filter((tag) => !usedSlugs.has(tag.slug))
  .map((tag) => ({ label: tag.label, slug: tag.slug, count: tagCountBySlug.get(tag.slug) ?? 0 }))
  .sort((a, b) => a.label.localeCompare(b.label))
---

{isPerusalOnlyMode ? (
  <PerusalOnlyRedirect />
) : (
<SiteLayout title="Browse Music" description="Browse all available works tags grouped by category." pageHero={pageHero} pageKey="music-browse">
  <ImmersivePageHeader
    title="Browse Music"
    subtitle={`Browse ${uniqueTags.length} tag${uniqueTags.length === 1 ? '' : 's'} and jump to filtered works. Prefer <a href="/music/">searching</a>?`}
  />

  <section>
    <div class="container works-tag-directory">
      {
        performerTags.length > 0 && (
          <section class="works-tag-directory-section">
            <h2>Performers</h2>
            <p class="works-tag-directory-description">Performers that appear across multiple works.</p>
            <div class="works-tag-directory-list">
              {performerTags.map((tag) => (
                <ImmersiveBadge href={`/music/browse/${tag.slug}/`}>
                  {tag.label}
                  <span class="works-tag-directory-count">({tag.count})</span>
                </ImmersiveBadge>
              ))}
            </div>
          </section>
        )
      }

      {
        ensembleTags.length > 0 && (
          <section class="works-tag-directory-section">
            <h2>Ensembles</h2>
            <p class="works-tag-directory-description">Ensembles that appear across multiple works.</p>
            <div class="works-tag-directory-list">
              {ensembleTags.map((tag) => (
                <ImmersiveBadge href={`/music/browse/${tag.slug}/`}>
                  {tag.label}
                  <span class="works-tag-directory-count">({tag.count})</span>
                </ImmersiveBadge>
              ))}
            </div>
          </section>
        )
      }

      {
        instrumentationTags.length > 0 && (
          <section class="works-tag-directory-section">
            <h2>Instrumentation</h2>
            <p class="works-tag-directory-description">Tags related to instrument families and instruments.</p>
            <div class="works-tag-directory-list">
              {instrumentationTags.map((tag) => (
                <ImmersiveBadge href={`/music/browse/${tag.slug}/`}>
                  {tag.label}
                  <span class="works-tag-directory-count">({tag.count})</span>
                </ImmersiveBadge>
              ))}
            </div>
          </section>
        )
      }

      {
        styleAndOtherTags.length > 0 && (
          <section class="works-tag-directory-section">
            <h2>Styles And Other</h2>
            <p class="works-tag-directory-description">Aesthetic, period, and other descriptive tags.</p>
            <div class="works-tag-directory-list">
              {styleAndOtherTags.map((tag) => (
                <ImmersiveBadge href={`/music/browse/${tag.slug}/`}>
                  {tag.label}
                  <span class="works-tag-directory-count">({tag.count})</span>
                </ImmersiveBadge>
              ))}
            </div>
          </section>
        )
      }

      {
        uncategorizedTags.length > 0 && (
          <section class="works-tag-directory-section">
            <h2>Other</h2>
            <div class="works-tag-directory-list">
              {uncategorizedTags.map((tag) => (
                <ImmersiveBadge href={`/music/browse/${tag.slug}/`}>
                  {tag.label}
                  <span class="works-tag-directory-count">({tag.count})</span>
                </ImmersiveBadge>
              ))}
            </div>
          </section>
        )
      }
    </div>
  </section>
</SiteLayout>
)}
