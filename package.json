{
  "name": "composer-website-astro",
  "description": "A professional, accessible portfolio website builder for composers. Built with Astro 5.",
  "version": "1.0.1",
  "author": "Incluud",
  "license": "MIT",
  "type": "module",
  "starterKit": {
    "exportName": "composer-website-starter",
    "publishBranch": "main",
    "publishRepoUrl": "https://github.com/jessevoogt/composer-website-starter.git"
  },
  "scripts": {
    "generate:data": "node ./scripts/generate-works-images.mjs && node ./scripts/generate-perusal-scores.mjs && node ./scripts/generate-page-search-index.mjs && node ./scripts/generate-api-config.mjs",
    "generate:branding": "node ./scripts/generate-branding-assets.mjs",
    "generate:social-image": "node ./scripts/generate-social-preview-image.mjs",
    "ingest:assets": "node ./scripts/generate-branding-assets.mjs && node ./scripts/ingest-assets.mjs",
    "ingest:works": "node ./scripts/ingest-works.mjs",
    "ingest:works:force": "node ./scripts/ingest-works.mjs --force",
    "cleanup:generated": "node ./scripts/cleanup-generated-files.mjs",
    "free:dev-ports": "node ./scripts/free-dev-ports.mjs",
    "dev": "node scripts/maybe-setup.mjs && npm run free:dev-ports && npm run ingest:assets && npm run ingest:works && npm run generate:data && astro dev --host 127.0.0.1 --open",
    "dev:full": "node scripts/maybe-setup.mjs && npm run free:dev-ports && npm run ingest:assets && npm run ingest:works && npm run generate:data && astro dev --host 127.0.0.1 --open",
    "start": "npm run ingest:assets && npm run generate:data && astro dev --host 127.0.0.1",
    "lint": "npx tsc --noEmit && npx eslint . && npx astro check",
    "build": "npm run ingest:assets && npm run generate:data && npm run lint && astro build && node ./scripts/check-trailing-slashes.mjs && node ./scripts/generate-redirects.mjs",
    "build:content": "npm run ingest:assets && npm run generate:social-image && npm run lint && astro build && node ./scripts/check-trailing-slashes.mjs && node ./scripts/generate-redirects.mjs",
    "build:full": "npm run ingest:assets && npm run ingest:works && npm run generate:data && npm run lint && astro build && node ./scripts/check-trailing-slashes.mjs && node ./scripts/generate-redirects.mjs",
    "deploy": "node ./scripts/deploy.mjs",
    "preview": "astro preview",
    "init:source": "node ./scripts/init-source.mjs",
    "init:source:reset": "node ./scripts/init-source.mjs --reset",
    "setup": "node scripts/setup-server.mjs",
    "postinstall": "npm run init:source",
    "quickstart": "npm install && npm run dev"
  },
  "keywords": [
    "astro",
    "astro-component",
    "astro-components",
    "accessible",
    "accessibility",
    "a11y",
    "wcag",
    "responsive",
    "ui-library",
    "ui-components",
    "blog",
    "works"
  ],
  "devDependencies": {
    "@astrojs/mdx": "^4.3.9",
    "@astrojs/node": "^9.5.4",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@iconify-json/lucide": "^1.2.66",
    "@types/js-yaml": "^4.0.9",
    "@types/page-flip": "^2.0.4",
    "@types/sanitize-html": "^2.13.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "astro": "^5.17.1",
    "astro-eslint-parser": "^1.2.2",
    "astro-icon": "^1.1.5",
    "eslint": "^9.35.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^16.4.0",
    "js-yaml": "^4.1.1",
    "pdf-to-png-converter": "^3.11.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-css-order": "^2.1.2",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.32.4",
    "ssh2-sftp-client": "^12.0.1",
    "svgo": "^4.0.1",
    "typescript": "^5.9.3",
    "sass": "^1.80.0"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/markdoc": "^0.15.10",
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.6.0",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.48",
    "@pdf-lib/fontkit": "^1.1.1",
    "astro-mail-obfuscation": "^2.3.4",
    "marked": "^17.0.3",
    "page-flip": "^2.0.7",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "overrides": {
    "lodash": "^4.17.23",
    "minimatch": "^10.2.2"
  }
}
