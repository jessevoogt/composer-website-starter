---
interface Props {
  src: string
  alt: string
  composerName: string
  width?: number | null
  height?: number | null
  isHomepage?: boolean
}

const { src, alt, composerName, width = null, height = null, isHomepage = false } = Astro.props

const resolvedAlt = alt.trim() || `${composerName} logo`
const styleParts: string[] = []

if (typeof width === 'number' && Number.isFinite(width) && width > 0) {
  styleParts.push(`--brand-logo-width: ${Math.round(width)}px`)
  styleParts.push('--brand-logo-max-width: none')
}

if (typeof height === 'number' && Number.isFinite(height) && height > 0) {
  styleParts.push(`--brand-logo-height: ${Math.round(height)}px`)
  styleParts.push('--brand-logo-max-height: none')
}

const logoStyle = styleParts.length > 0 ? styleParts.join('; ') : undefined
---

<a
  href="/"
  class:list={['brand', 'brand-image-mode', isHomepage && 'brand-home-image']}
  aria-label={`${composerName} home`}
>
  <img
    class="brand-image-logo"
    src={src}
    alt={resolvedAlt}
    width={typeof width === 'number' ? width : undefined}
    height={typeof height === 'number' ? height : undefined}
    style={logoStyle}
    loading="eager"
    decoding="async"
  />
</a>

<style>
  .brand.brand-image-mode {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .brand.brand-image-mode:hover,
  .brand.brand-image-mode:focus-visible {
    opacity: 0.92;
  }

  .brand-image-logo {
    display: block;
    width: var(--brand-logo-width, auto);
    height: var(--brand-logo-height, auto);
    max-width: var(--brand-logo-max-width, min(58vw, 20rem));
    max-height: var(--brand-logo-max-height, 3.4rem);
    object-fit: contain;
    filter: drop-shadow(0 2px 10px rgb(0 0 0 / 0.28));
  }
</style>
