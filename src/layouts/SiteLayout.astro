---
import '../styles/site.css'
import {
  getSiteConfig,
  getThemeConfig,
  getPrimaryNavLinks,
  getSocialLinks,
  getBrandConfig,
  getBreadcrumbsConfig,
  getCopyrightConfig,
  getFooterMenuConfig,
  getResponsiveHeaderConfigs,
  anyHeaderHasElement,
  getFooterBlockConfig,
  getGlobalLayout,
  isPlaceholderConfig,
  getFeaturedPlayerConfig,
} from '@/utils/source-config'
import {
  DEFAULT_THEME_FONT_BODY,
  DEFAULT_THEME_FONT_HEADING,
  normalizeThemeFontValue,
  resolveThemeFontFamily,
  resolveImmersiveButtonLabelShifts,
  getThemeGoogleFontsStylesheetHref,
} from '@/utils/theme-fonts'
import {
  normalizeThemeColors,
  normalizeHexColorExact,
  toThemeCssVars,
  toThemeStyleString,
} from '@/utils/theme-css-vars'
import { THEME_PRESETS, THEME_COLOR_KEYS } from '@/utils/theme-presets'
import type { HeaderElement, HeaderBreakpoint } from '@/utils/source-config'
import { getBrandPluginId } from '@/utils/brand-plugin'
import SiteMeta from '@components/SiteMeta.astro'
import GoogleAnalytics from '@components/GoogleAnalytics.astro'
import SocialIcon from '@components/icons/SocialIcon.astro'
import BrandRenderer from '@components/brand/BrandRenderer.astro'
import ImmersiveBreadcrumbs from '@components/immersive/ImmersiveBreadcrumbs.astro'
import WorksSearch from '@components/WorksSearch.astro'
import { ClientRouter } from 'astro:transitions'
import { getCollection } from 'astro:content'
const primaryNavLinks = getPrimaryNavLinks()
const socialLinks = getSocialLinks()
const copyrightConfig = getCopyrightConfig()
const footerMenuConfig = getFooterMenuConfig()
const responsiveHeaders = getResponsiveHeaderConfigs()
const footerBlockConfig = getFooterBlockConfig()
const globalLayout = getGlobalLayout()
const visibleBlocks = new Set(globalLayout.sections.map((s) => s.key))
const brandConfig = getBrandConfig()
const brandPluginId = getBrandPluginId(brandConfig)
const hasCustomBrandPlugin = brandPluginId === 'custom-animation'
import type { SearchableItem, SearchableWorkItem } from '../scripts/search-types'
import { generatedPageSearchEntries } from '@data/generated-page-search-metadata'
import { resolveNavHref } from '@/utils/resolve-nav-href'
import prepareWorks from '@/utils/prepareWorks'
import { buildSearchableTagItems, buildSearchableWorkItems } from '@/utils/search-items'
import worksImages from '@/utils/works-images'
import { flattenRecordingEntries } from '@/utils/immersive-helpers'
import perusalScores from '@/utils/perusal-scores'
import type { ClientRecordingEntry } from '../scripts/immersive/types'
import type { PageHero } from '@/utils/page-hero'
import { getHeroVariants, getHeroConfig } from '@/utils/source-config'

interface Props {
  title?: string
  description?: string
  url?: URL | string
  image?: string
  imageAlt?: string
  author?: string
  robots?: string
  isHomepage?: boolean
  skipTargetId?: string
  pageContentClass?: string
  bodyClass?: string
  customBreadcrumbLabels?: Record<string, string>
  headerBreadcrumbItems?: Array<{ href?: string; label: string; currentPage?: boolean }>
  replaceLastAutoBreadcrumbLabel?: string
  pageHero?: PageHero | null
  pageKey?: 'home' | 'contact' | 'about' | 'works' | string
  /** Work slug — enables per-work background scope in the dev toolbar. */
  workSlug?: string
  /** The work-detail page-level default hero id (before per-work override). */
  pageDefaultHeroId?: string
}

const siteConfig = getSiteConfig()
const themeConfig = getThemeConfig()

// Redirect to setup wizard if still using placeholder config (dev mode only)
const isSetupNeeded = import.meta.env.DEV && isPlaceholderConfig()

// Resolve theme colors, fonts, and border radius
const resolvedThemeColors = normalizeThemeColors(themeConfig)
const resolvedFontBody = normalizeThemeFontValue(themeConfig.fontBody, DEFAULT_THEME_FONT_BODY)
const resolvedFontHeading = normalizeThemeFontValue(themeConfig.fontHeading, DEFAULT_THEME_FONT_HEADING)
const resolvedBorderRadius = themeConfig.borderRadius || 'none'

// Match the current YAML theme against presets to pick up overrides like focusRingColor
const matchedPreset = THEME_PRESETS.find(
  (preset) =>
    THEME_COLOR_KEYS.every((key) => {
      const a = normalizeHexColorExact(resolvedThemeColors[key])
      const b = normalizeHexColorExact(preset.colors[key])
      return a && b && a === b
    }) && (preset.borderRadius || 'none') === resolvedBorderRadius,
)

const resolvedCtaBackground = themeConfig.ctaBackground.trim() || matchedPreset?.ctaBackground || ''
const resolvedCtaText = themeConfig.ctaText.trim() || matchedPreset?.ctaText || ''
const resolvedFocusRingColor = themeConfig.focusRingColor.trim() || matchedPreset?.focusRingColor || ''
const resolvedNavActiveUnderline = themeConfig.navActiveUnderline.trim() || matchedPreset?.navActiveUnderline || ''
const resolvedNavActiveText = themeConfig.navActiveText.trim() || matchedPreset?.navActiveText || ''
const resolvedNavHoverUnderline = themeConfig.navHoverUnderline.trim() || matchedPreset?.navHoverUnderline || ''
const resolvedNavHoverText = themeConfig.navHoverText.trim() || matchedPreset?.navHoverText || ''
const resolvedScrimColor = themeConfig.scrimColor.trim() || matchedPreset?.scrimColor || ''
const resolvedDisableImageOverlays = themeConfig.disableImageOverlays
const resolvedPlayerBorderRadius = themeConfig.playerBorderRadius.trim()
const resolvedSocialIconBorderRadius = themeConfig.socialIconBorderRadius.trim()
const resolvedProfileImageBorderRadius =
  themeConfig.profileImageBorderRadius.trim() || matchedPreset?.profileImageBorderRadius || 'circle'
const resolvedTagBadgeBorderRadius =
  themeConfig.tagBadgeBorderRadius.trim() || matchedPreset?.tagBadgeBorderRadius || 'circle'
const resolvedThemeId = themeConfig.currentThemeId.trim() || matchedPreset?.id || ''
const resolvedThemeCustomCss = themeConfig.customCss.trim()
const resolvedAboutPage = themeConfig.aboutPage
const resolvedContactPage = themeConfig.contactPage

const themeVars = toThemeCssVars(
  resolvedThemeColors,
  resolvedBorderRadius,
  resolvedFocusRingColor,
  resolvedCtaBackground,
  resolvedCtaText,
  resolvedNavActiveUnderline,
  resolvedNavActiveText,
  resolvedNavHoverUnderline,
  resolvedNavHoverText,
  resolvedScrimColor,
  resolvedDisableImageOverlays,
  resolvedPlayerBorderRadius,
  resolvedSocialIconBorderRadius,
  resolvedProfileImageBorderRadius,
  resolvedTagBadgeBorderRadius,
  resolvedAboutPage.profileImagePosition,
  resolvedAboutPage.position,
  resolvedAboutPage.maxWidth,
  resolvedContactPage.position,
  resolvedContactPage.maxWidth,
)
themeVars['--font-heading'] = resolveThemeFontFamily(resolvedFontHeading, DEFAULT_THEME_FONT_HEADING)
themeVars['--font-body'] = resolveThemeFontFamily(resolvedFontBody, DEFAULT_THEME_FONT_BODY)
const immersiveLabelShifts = resolveImmersiveButtonLabelShifts(resolvedFontHeading, DEFAULT_THEME_FONT_HEADING)
themeVars['--immersive-btn-label-shift-standard'] = immersiveLabelShifts.standard
themeVars['--immersive-btn-label-shift-control'] = immersiveLabelShifts.control
const themeStyleVars = toThemeStyleString(themeVars)

const googleFontsStylesheetHref = getThemeGoogleFontsStylesheetHref([
  { value: resolvedFontBody, fallback: DEFAULT_THEME_FONT_BODY },
  { value: resolvedFontHeading, fallback: DEFAULT_THEME_FONT_HEADING },
])

const {
  title = siteConfig.siteTitle,
  description = siteConfig.siteDescription,
  url = Astro.site,
  image = '/social-preview-image.png',
  imageAlt = `${siteConfig.composerName} monogram and wordmark`,
  author = siteConfig.composerName,
  robots,
  isHomepage = false,
  skipTargetId = 'main-content',
  pageContentClass,
  bodyClass,
  customBreadcrumbLabels,
  headerBreadcrumbItems: customHeaderBreadcrumbItems,
  replaceLastAutoBreadcrumbLabel,
  pageHero,
  pageKey,
  workSlug,
  pageDefaultHeroId,
} = Astro.props

const year = new Date().getFullYear()
const currentPath = Astro.url.pathname
const pathSegments = currentPath.split('/').filter(Boolean)
const breadcrumbsConfig = getBreadcrumbsConfig()

// Header slot system — three responsive layouts, each with independent slot arrays
const anyHasMobileMenu = anyHeaderHasElement(responsiveHeaders, 'mobile-menu')

type SlotPosition = 'left' | 'center' | 'right'
const breakpointOrder: HeaderBreakpoint[] = ['desktop', 'tablet', 'mobile']

const showHeaderBreadcrumbs =
  visibleBlocks.has('breadcrumbs') &&
  !isHomepage &&
  (currentPath !== '/' || Boolean(customHeaderBreadcrumbItems?.length) || Boolean(replaceLastAutoBreadcrumbLabel))
const worksCollection = await getCollection('works')
const { works: worksWithImages, uniqueTags } = prepareWorks(worksCollection)

function resolveImagePath(value: string | undefined): string {
  if (!value) return ''
  const normalized = value.trim().toLowerCase()
  const matched = worksImages.find((image) => image.path.toLowerCase() === normalized)
  return matched ? matched.data.src : value
}

const defaultFallbackImage = { src: '', alt: 'Recording image', position: '50% 50%' }
const allRecordingEntries = flattenRecordingEntries(
  worksWithImages,
  resolveImagePath,
  defaultFallbackImage,
  perusalScores,
)

const featuredPlayerConfig = getFeaturedPlayerConfig()
const featuredRecordings = allRecordingEntries.filter((entry) => entry.mp3)
const fallbackRecording = allRecordingEntries.find((entry) => entry.mp3) ?? null

const featuredPlayerRecordings: ClientRecordingEntry[] =
  featuredRecordings.length > 0 ? featuredRecordings : fallbackRecording ? [fallbackRecording] : []

const isFeaturedPlayerEnabled = featuredPlayerConfig.enabled && featuredPlayerRecordings.length > 0
const isPlayerInHeaderCenter = isFeaturedPlayerEnabled && featuredPlayerConfig.position === 'header-center'
const serializedFeaturedPlayerRecordings = JSON.stringify(featuredPlayerRecordings)
const serializedFeaturedPlayerConfig = JSON.stringify({
  position: featuredPlayerConfig.position,
  showScrubber: featuredPlayerConfig.showScrubber,
  showMuteToggle: featuredPlayerConfig.showMuteToggle,
  showVolumeControl: featuredPlayerConfig.showVolumeControl,
  showDuration: featuredPlayerConfig.showDuration,
  showInfoButton: featuredPlayerConfig.showInfoButton,
  showTrackInfo: featuredPlayerConfig.showTrackInfo,
  trackInfoScrollingText: featuredPlayerConfig.trackInfoScrollingText,
  showPrevButton: featuredPlayerConfig.showPrevButton,
  showNextButton: featuredPlayerConfig.showNextButton,
})
const candidateWorkIdForInitialRecording =
  pathSegments.length === 2 && pathSegments[0] === 'works' ? pathSegments[1] : undefined
const workIdForInitialRecording =
  candidateWorkIdForInitialRecording && worksWithImages.some((work) => work.id === candidateWorkIdForInitialRecording)
    ? candidateWorkIdForInitialRecording
    : undefined
const initialWorkRecording = workIdForInitialRecording
  ? featuredPlayerRecordings.find((entry) => entry.workId === workIdForInitialRecording)
  : undefined
const initialFeaturedRecordingKey = initialWorkRecording?.key
const defaultFeaturedAudioSrc =
  initialWorkRecording?.mp3 ?? featuredPlayerRecordings[0]?.mp3 ?? '/audio/featured-track.mp3'

const searchableWorkItems: SearchableWorkItem[] = buildSearchableWorkItems(worksWithImages)
const searchableTagItems = buildSearchableTagItems(uniqueTags)
const searchableMusicItems: SearchableItem[] = [...searchableWorkItems, ...searchableTagItems]
const searchableItems: SearchableItem[] = [...searchableMusicItems, ...generatedPageSearchEntries]
const serializedMusicSearchItems = JSON.stringify(searchableMusicItems)
const serializedSearchItems = JSON.stringify(searchableItems)

type BreadcrumbItem = { href?: string; label: string; currentPage?: boolean }

const formatSegmentLabel = (segment: string): string => {
  if (customBreadcrumbLabels?.[segment]) {
    return customBreadcrumbLabels[segment]
  }
  return decodeURIComponent(segment)
    .split('-')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ')
}

const autoHeaderBreadcrumbItems: BreadcrumbItem[] = []

if (showHeaderBreadcrumbs) {
  autoHeaderBreadcrumbItems.push({ href: '/', label: breadcrumbsConfig.homeCrumbLabel || 'Home' })
  pathSegments.forEach((segment, index) => {
    const url = `/${pathSegments.slice(0, index + 1).join('/')}/`
    const isLast = index === pathSegments.length - 1
    const isNumericPageSegment = /^\d+$/.test(segment)

    autoHeaderBreadcrumbItems.push({
      href: isLast ? undefined : url,
      label: isNumericPageSegment ? `Page ${segment}` : formatSegmentLabel(segment),
      currentPage: isLast,
    })
  })
}

const knownWorkIdSet = new Set(worksWithImages.map((work) => work.id))
const knownTagSlugSet = new Set(uniqueTags.map((tag) => tag.slug))
const knownBreadcrumbPathSet = new Set(
  [
    ...generatedPageSearchEntries.map((entry) => entry.href),
    ...primaryNavLinks.map((link) => link.href),
    ...worksWithImages.map((work) => `/music/${work.id}/`),
    ...worksWithImages
      .filter((work) => Boolean(perusalScores[work.id]))
      .map((work) => `/music/${work.id}/perusal-score/`),
    ...worksWithImages
      .filter((work) => Boolean(perusalScores[work.id]))
      .map((work) => `/music/${work.id}/perusal-score/thank-you/`),
    ...worksWithImages
      .filter((work) => Boolean(perusalScores[work.id]))
      .map((work) => `/music/${work.id}/perusal-score/access-granted/`),
    ...uniqueTags.map((tag) => `/music/browse/${tag.slug}/`),
  ].map((path) => normalizePath(path)),
)

function normalizePath(path: string): string {
  if (!path) return '/'
  let normalized = path.startsWith('/') ? path : `/${path}`
  normalized = normalized.replace(/\/+/g, '/')
  if (normalized !== '/' && !normalized.endsWith('/')) normalized += '/'
  return normalized
}

function isKnownBreadcrumbPath(path: string): boolean {
  const normalized = normalizePath(path)
  if (knownBreadcrumbPathSet.has(normalized)) return true

  const workDetailMatch = normalized.match(/^\/music\/([^/]+)\/$/)
  if (workDetailMatch) {
    return knownWorkIdSet.has(workDetailMatch[1])
  }

  const perusalMatch = normalized.match(/^\/music\/([^/]+)\/perusal-score\/$/)
  if (perusalMatch) {
    const workId = perusalMatch[1]
    return knownWorkIdSet.has(workId) && Boolean(perusalScores[workId])
  }

  const tagPaginationMatch = normalized.match(/^\/music\/browse\/([^/]+)\/(\d+)\/$/)
  if (tagPaginationMatch) {
    const [, tagSlug, page] = tagPaginationMatch
    return knownTagSlugSet.has(tagSlug) && Number(page) >= 1
  }

  return false
}

function buildValidAutoBreadcrumbPrefixItems(): BreadcrumbItem[] {
  const validPrefixItems: BreadcrumbItem[] = [{ href: '/', label: breadcrumbsConfig.homeCrumbLabel || 'Home' }]

  for (let index = 0; index < pathSegments.length; index += 1) {
    const segment = pathSegments[index]
    const url = `/${pathSegments.slice(0, index + 1).join('/')}/`
    if (!isKnownBreadcrumbPath(url)) break

    const isNumericPageSegment = /^\d+$/.test(segment)
    validPrefixItems.push({
      href: url,
      label: isNumericPageSegment ? `Page ${segment}` : formatSegmentLabel(segment),
    })
  }

  return validPrefixItems
}

const notFoundBreadcrumbItems =
  replaceLastAutoBreadcrumbLabel && replaceLastAutoBreadcrumbLabel.trim().length > 0
    ? [
        ...buildValidAutoBreadcrumbPrefixItems().map((item) => ({ ...item, currentPage: false })),
        { label: replaceLastAutoBreadcrumbLabel.trim(), currentPage: true },
      ]
    : null

const resolvedHeaderBreadcrumbItems =
  customHeaderBreadcrumbItems && customHeaderBreadcrumbItems.length > 0
    ? customHeaderBreadcrumbItems
    : notFoundBreadcrumbItems && notFoundBreadcrumbItems.length > 0
      ? notFoundBreadcrumbItems
      : autoHeaderBreadcrumbItems
const hasHeaderBreadcrumbs = showHeaderBreadcrumbs && resolvedHeaderBreadcrumbItems.length > 1

const pageHeroStyle =
  pageHero && pageHero.src
    ? [
        `--page-hero-image: url('${pageHero.src}')`,
        `--page-hero-position: ${pageHero.position || '50% 50%'}`,
        `--page-hero-filter: ${pageHero.filter || 'none'}`,
      ].join('; ')
    : undefined

// Hero switcher toolbar data (dev mode only)
const heroVariantEventName = 'jv:immersive:hero-variant:set'
const isDevMode = import.meta.env.DEV
const heroToolbarData = isDevMode
  ? (() => {
      const allHeroVariants = getHeroVariants()
      const heroConfig = getHeroConfig()
      return JSON.stringify({
        pageKey: isHomepage ? 'home' : (pageKey ?? ''),
        heroVariants: allHeroVariants,
        fallbackHeroSrc:
          allHeroVariants.find((v) => v.id === heroConfig.fallbackHeroId)?.src ?? allHeroVariants[0]?.src ?? '',
        defaultHeroFilter: heroConfig.defaultFilter,
        heroVariantEventName,
        devMode: true,
        ...(workSlug ? { workSlug } : {}),
        ...(pageDefaultHeroId ? { pageDefaultHeroId } : {}),
      })
    })()
  : null

const themeToolbarData = isDevMode
  ? JSON.stringify({
      currentThemeId: themeConfig.currentThemeId.trim(),
      colors: resolvedThemeColors,
      rawColors: {
        colorBackground: themeConfig.colorBackground.trim(),
        colorBackgroundSoft: themeConfig.colorBackgroundSoft.trim(),
        colorText: themeConfig.colorText.trim(),
        colorTextMuted: themeConfig.colorTextMuted.trim(),
        colorAccent: themeConfig.colorAccent.trim(),
        colorAccentStrong: themeConfig.colorAccentStrong.trim(),
        colorButton: themeConfig.colorButton.trim(),
        colorButtonText: themeConfig.colorButtonText.trim(),
      },
      focusRingColor: resolvedFocusRingColor,
      navActiveUnderline: resolvedNavActiveUnderline,
      navActiveText: resolvedNavActiveText,
      navHoverUnderline: resolvedNavHoverUnderline,
      navHoverText: resolvedNavHoverText,
      scrimColor: resolvedScrimColor,
      disableImageOverlays: resolvedDisableImageOverlays,
      ctaBackground: resolvedCtaBackground,
      ctaText: resolvedCtaText,
      fontBody: resolvedFontBody,
      fontHeading: resolvedFontHeading,
      borderRadius: resolvedBorderRadius,
      playerBorderRadius: resolvedPlayerBorderRadius,
      socialIconBorderRadius: resolvedSocialIconBorderRadius,
      profileImageBorderRadius: resolvedProfileImageBorderRadius,
      tagBadgeBorderRadius: resolvedTagBadgeBorderRadius,
      customCss: themeConfig.customCss,
      aboutPage: themeConfig.aboutPage,
      contactPage: themeConfig.contactPage,
      homeHero: themeConfig.homeHero,
    })
  : null
---

<html
  lang="en"
  dir="ltr"
  style={themeStyleVars}
  class:list={[isHomepage && hasCustomBrandPlugin && 'home-intro-animating']}
  data-theme-id={resolvedThemeId || undefined}
  data-page={isHomepage ? 'home' : undefined}
  data-has-header-breadcrumbs={hasHeaderBreadcrumbs ? 'true' : undefined}
  data-player-position={isFeaturedPlayerEnabled ? featuredPlayerConfig.position : undefined}
>
  <head>
    {isSetupNeeded && Astro.url.pathname !== '/setup/' && <meta http-equiv="refresh" content="0;url=/setup/" />}
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />

    {
      googleFontsStylesheetHref && (
        <>
          <link rel="preconnect" href="https://fonts.googleapis.com" />
          <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
          <link rel="stylesheet" href={googleFontsStylesheetHref} />
        </>
      )
    }

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=6" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png?v=6" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=6" />
    <link rel="shortcut icon" href="/favicon.ico?v=6" />
    <meta name="apple-mobile-web-app-title" content={siteConfig.composerName} />
    <link rel="manifest" href="/site.webmanifest" />

    <SiteMeta
      title={title}
      description={description}
      url={String(url)}
      image={image}
      imageAlt={imageAlt}
      author={author}
      robots={robots}
    />
    <GoogleAnalytics />
    <ClientRouter />
    <script is:inline>
    (function(){
      // Studio preview bridge — self-activating: only runs inside the studio
      // preview iframe (detected by query param + being in a frame).
      if(window.parent===window)return;
      if(!new URLSearchParams(location.search).has('cmsLivePreview'))return;
      if(window.__pvBridge)return;
      window.__pvBridge=true;

      // Report navigations to studio shell (fires on initial load + after View Transitions)
      document.addEventListener('astro:page-load',function(){
        var is404=!!document.querySelector('.not-found-section');
        window.parent.postMessage({type:'preview-navigate',pathname:location.pathname,is404:is404},location.origin);
      });

      // Intercept link clicks — let studio shell check unsaved changes BEFORE navigating
      document.addEventListener('click',function(e){
        var t=e.target.closest('a[href]');
        if(!t)return;
        if(e.button!==0||e.metaKey||e.ctrlKey||e.shiftKey)return;
        if(t.target==='_blank'||t.hasAttribute('download'))return;
        var h=t.getAttribute('href');
        if(!h||h.charAt(0)==='#'||h.indexOf('mailto:')===0||h.indexOf('tel:')===0)return;
        try{var u=new URL(h,location.href);if(u.origin!==location.origin)return}catch(x){return}
        e.preventDefault();e.stopImmediatePropagation();
        window.parent.postMessage({type:'preview-request-navigate',pathname:u.pathname},location.origin);
      },true);

      // Receive navigation commands from studio shell.
      // Use location.replace() to avoid polluting the session history — all
      // frames share a single history stack and iframe entries would break
      // parent back/forward navigation.
      window.addEventListener('message',function(e){
        if(e.origin!==location.origin)return;
        if(e.data&&e.data.type==='preview-do-navigate'){
          window.location.replace(e.data.pathname+(e.data.pathname.indexOf('?')===-1?'?':'&')+'cmsLivePreview=1');
        }
      });
    })();
    </script>
    {resolvedThemeCustomCss && <style id="site-theme-custom-css" is:inline set:html={resolvedThemeCustomCss} />}
    <noscript>
      <style>
        html[data-page='home'] [data-brand-link] {
          visibility: visible !important;
        }
      </style>
    </noscript>
  </head>
  <body data-page={isHomepage ? 'home' : undefined} class:list={[bodyClass]}>
    <a class="skip-link" href={`#${skipTargetId}`}>Skip to main content</a>

    {
      visibleBlocks.has('header') && (
        <header class="site-header" aria-label="Site header">
          {breakpointOrder.map((bp) => {
            const config = responsiveHeaders[bp]
            const slots: { position: SlotPosition; order: number; elements: HeaderElement[] }[] = [
              { position: 'left', order: 1, elements: config.left },
              { position: 'center', order: 2, elements: config.center },
              { position: 'right', order: 3, elements: config.right },
            ]
            return (
              <div class="header-layout" data-header-layout={bp}>
                {slots.flatMap(({ position, order, elements }) => {
                  const result: any[] = []
                  if (elements.length > 0) {
                    result.push(
                    <div class="header-slot" data-slot={position} style={`order: ${order}`}>
                      {elements.map((element) => {
                        if (element === 'brand-logo') {
                          return (
                            <div class="brand-slot">
                              <BrandRenderer
                                brandConfig={brandConfig}
                                composerName={siteConfig.composerName}
                                isHomepage={isHomepage}
                              />
                            </div>
                          )
                        }
                        if (element === 'main-menu') {
                          return (
                            <nav class="desktop-nav" aria-label="Primary navigation">
                              <ul>
                                {primaryNavLinks.map((link) => {
                                  const href = resolveNavHref(link, currentPath)
                                  const isCurrent = !link.anchorTarget && currentPath.startsWith(link.href)
                                  return (
                                    <li>
                                      <a href={href} aria-current={isCurrent ? 'page' : undefined}>
                                        {link.label}
                                      </a>
                                    </li>
                                  )
                                })}
                              </ul>
                            </nav>
                          )
                        }
                        if (element === 'site-search') {
                          return (
                            <button
                              type="button"
                              class="menu-search-toggle"
                              data-works-search-modal-toggle
                              {...(anyHasMobileMenu ? { 'data-mobile-header-search-toggle': '' } : {})}
                              aria-controls={
                                anyHasMobileMenu ? 'works-search-modal mobile-menu-modal' : 'works-search-modal'
                              }
                              aria-expanded="false"
                              aria-label="Open search"
                            >
                              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
                                <circle cx="11" cy="11" r="6.5" />
                                <path d="M16.2 16.2L21 21" />
                              </svg>
                            </button>
                          )
                        }
                        if (element === 'mobile-menu') {
                          return (
                            <div class="menu-toggle-slot" data-menu-toggle-slot>
                              <button
                                type="button"
                                class="menu-toggle"
                                data-menu-toggle
                                aria-controls="mobile-menu-modal"
                                aria-expanded="false"
                                aria-label="Open menu"
                              >
                                <span class="sr-only">Menu</span>
                                <span class="menu-toggle-icon" aria-hidden="true">
                                  <span class="menu-toggle-line menu-toggle-line-top" />
