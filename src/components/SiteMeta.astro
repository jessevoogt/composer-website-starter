---
import { SOCIAL_IMAGE_VERSION } from '@data/social-image-version'
import { getSiteConfig } from '@/utils/source-config'

/**
 * SiteMeta Component
 *
 * @description Component to handle site metadata and essential head elements
 */
interface Props {
  /**
   * The title of the page
   */
  title: string
  /**
   * The description of the page
   */
  description: string
  /**
   * The URL of the page
   */
  url: string
  /**
   * The image path for social sharing
   */
  image: string
  /**
   * The author of the page
   */
  author?: string
  /**
   * The social image alt text
   */
  imageAlt?: string
  /**
   * Facebook App ID for Open Graph integrations
   */
  facebookAppId?: string
  /**
   * Open Graph object type
   */
  type?: 'website' | 'article'
}

const siteConfig = getSiteConfig()

const {
  title,
  description,
  url,
  image,
  author = siteConfig.composerName,
  imageAlt = `${siteConfig.composerName} social preview image`,
  facebookAppId,
  type = 'website',
} = Astro.props

const siteName = siteConfig.composerName
const normalizedTitle = title.trim()
const normalizedSiteName = siteName.trim()
const shouldAppendSiteName =
  normalizedSiteName.length > 0 && !normalizedTitle.toLowerCase().includes(normalizedSiteName.toLowerCase())
const fullTitle = shouldAppendSiteName ? `${normalizedTitle} | ${normalizedSiteName}` : normalizedTitle
const normalizedImageAlt = imageAlt.trim()
const resolvedImageAlt =
  normalizedImageAlt.length > 0 ? normalizedImageAlt : `${normalizedTitle || normalizedSiteName} social preview image`
const resolvedFacebookAppId = [facebookAppId, import.meta.env.PUBLIC_FACEBOOK_APP_ID, import.meta.env.PUBLIC_FB_APP_ID]
  .map((value) => (typeof value === 'string' ? value.trim() : ''))
  .find((value) => value.length > 0)

function toAbsoluteUrl(value: string): string {
  try {
    if (Astro.site) {
      return new URL(value, Astro.site).toString()
    }
    return new URL(value, Astro.url).toString()
  } catch {
    return value
  }
}

function withSocialImageVersion(value: string): string {
  try {
    const base = Astro.site ?? Astro.url
    const url = new URL(value, base)
    if (!url.pathname.endsWith('/social-preview-image.png')) {
      return value
    }
    url.searchParams.set('v', SOCIAL_IMAGE_VERSION)
    return url.toString()
  } catch {
    return value
  }
}

const canonicalUrl = toAbsoluteUrl(url)
const socialImageUrl = withSocialImageVersion(toAbsoluteUrl(image))
---

<link rel="canonical" href={canonicalUrl} />

<!-- general meta -->
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<meta name="author" content={author} />

<!-- open graph -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteName} />
<meta property="og:url" content={canonicalUrl} />
{resolvedFacebookAppId ? <meta property="fb:app_id" content={resolvedFacebookAppId} /> : null}
<meta property="og:image" content={socialImageUrl} />
<meta property="og:image:secure_url" content={socialImageUrl} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={resolvedImageAlt} />
<meta name="og:image:alt" content={resolvedImageAlt} />

<!-- twitter card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={socialImageUrl} />
<meta name="twitter:image:alt" content={resolvedImageAlt} />

<!-- page title -->
<title>{fullTitle}</title>
