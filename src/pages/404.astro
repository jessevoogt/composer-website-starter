---
import SiteLayout from '@layouts/SiteLayout.astro'
import ButtonLink from '@components/ui/ButtonLink.astro'
import UiIcon from '@components/icons/UiIcon.astro'
import { getRedirects, getNotFoundPage } from '@/utils/source-config'
import { resolvePageHero } from '@/utils/page-hero'

const notFoundPage = getNotFoundPage()
const { pageHero } = resolvePageHero(notFoundPage.preferredHeroId)
const { rules } = getRedirects()
const activeRules = rules
  .filter((r) => r.enabled && r.type !== '410')
  .map(({ from, to, matchType }) => ({ from, to, matchType }))
---

<SiteLayout
  title={notFoundPage.title || '404'}
  replaceLastAutoBreadcrumbLabel="Page Not Found"
  pageHero={pageHero}
  pageKey="not-found"
>
  <section class="page-header-section not-found-section">
    <div class="not-found-bg" aria-hidden="true">
      <svg viewBox="0 0 310.598 310.598" xmlns="http://www.w3.org/2000/svg">
        <!-- Caesura (//) — CC0, SVG Repo -->
        <polygon points="239.5,50.299 106,260.299 177.098,260.299 310.598,50.299" fill="currentColor"/>
        <polygon points="204.598,50.299 133.5,50.299 0,260.299 71.098,260.299"   fill="currentColor"/>
      </svg>
    </div>

    <div class="page-header-inner not-found-inner">
      <h1>{notFoundPage.title || '404'}</h1>
      <p class="not-found-message">{notFoundPage.message || "The page you requested isn't in the score."}</p>
      <p class="not-found-status">{notFoundPage.submessage || "Don't worry, the music doesn't have to end."}</p>
      <ButtonLink href="/" variant="primary" class="not-found-home-link">
        <span slot="icon-left" class="not-found-home-link-icon" aria-hidden="true">
          <UiIcon name="arrowRight" size="1.05rem" />
        </span>
        {notFoundPage.buttonLabel || 'Da capo'}
      </ButtonLink>
    </div>
  </section>
</SiteLayout>

<script is:inline define:vars={{ activeRules }}>
  // Client-side redirect fallback — matches the .htaccess rules so redirects work
  // on non-Apache servers (e.g. Astro dev, Cloudflare, Nginx) and locally in dev.
  ;(() => {
    const path = window.location.pathname
    for (const rule of activeRules) {
      const from = rule.from.replace(/\/$/, '')
      if (rule.matchType === 'prefix') {
        const bare = from + '/'
        if (path === bare || path.startsWith(bare)) {
          const rest = path.slice(bare.length)
          window.location.replace(rule.to + rest)
          return
        }
        if (path === from) {
          window.location.replace(rule.to)
          return
        }
      } else {
        if (path === from || path === from + '/') {
          window.location.replace(rule.to)
          return
        }
      }
    }
  })()
</script>

<script is:inline>
  // Rebuild breadcrumbs from the actual browser URL (the static 404.html was built
  // with pathname "/404/", but Apache's ErrorDocument serves it at the original URL).
  ;(() => {
    const ol = document.querySelector('.site-header-breadcrumbs .breadcrumbs ol')
    if (!ol) return

    const segments = window.location.pathname.split('/').filter(Boolean)
    if (segments.length <= 1) return // "Home / Page Not Found" is fine as-is

    const fmt = (s) =>
      /^\d+$/.test(s)
        ? 'Page ' + s
        : decodeURIComponent(s)
            .split('-')
            .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
            .join(' ')

    let html = '<li><a href="/">Home</a></li>'
    for (let i = 0; i < segments.length - 1; i++) {
      const href = '/' + segments.slice(0, i + 1).join('/') + '/'
      html += '<li><a href="' + href + '">' + fmt(segments[i]) + '</a></li>'
    }
    html += '<li><span aria-current="page">Page Not Found</span></li>'

    ol.innerHTML = html
  })()
</script>

<style>
  .not-found-section {
    position: relative;
    overflow: hidden;
    display: flex;
    min-height: calc(100svh - var(--header-height) - var(--header-breadcrumb-height));
    align-items: center;
  }

  .not-found-bg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    color: var(--ink);
    opacity: 0.045;
  }

  .not-found-bg svg {
    width: min(80%, 44rem);
    height: auto;
  }

  .not-found-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-s);
    text-align: center;
  }

  .not-found-inner h1 {
    font-size: var(--font-size-6);
    margin-bottom: 0;
    line-height: 1;
  }

  .not-found-message {
    font-size: var(--font-size-2);
    color: var(--ink-soft);
    max-width: 40ch;
  }

  .not-found-status {
    font-size: var(--font-size--1);
    color: color-mix(in srgb, var(--ink-soft) 68%, transparent);
    font-weight: 400;
    letter-spacing: 0.03em;
    max-width: 40ch;
  }

  .not-found-home-link {
    gap: 0.52rem;
  }

  .not-found-home-link-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 1.05rem;
    width: 1.05rem;
    height: 1.05rem;
    min-width: 1.05rem;
    min-height: 1.05rem;
    transform: scaleX(-1);
    transition: transform 180ms ease;
  }

  .not-found-home-link-icon svg {
    width: 1.05rem;
    height: 1.05rem;
    display: block;
  }

  @media (hover: hover) and (pointer: fine) {
    .not-found-home-link:not(:disabled):hover .not-found-home-link-icon {
      transform: scaleX(-1) translateX(0.2rem);
    }
  }
</style>
