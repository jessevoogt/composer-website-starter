---
interface Props {
  href: string
  class?: string
  isExternal?: boolean
  [key: string]: unknown
}

const {
  href,
  class: className,
  isExternal = false,
  ...rest
} = Astro.props

const externalAttrs = isExternal ? { target: '_blank', rel: 'noreferrer noopener' } : {}
---

<a href={href} class={className} {...externalAttrs} {...rest}>
  <slot />
</a>
