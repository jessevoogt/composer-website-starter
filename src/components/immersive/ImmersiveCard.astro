---
import { Image } from 'astro:assets'
import worksImages from '@/utils/works-images'

type ImageData = typeof worksImages[number]['data']

interface Props {
  url: string
  title: string
  headingLevel?: 'h2' | 'h3'
  footer?: string
  class?: string
  imageData?: ImageData | null
  imageSrc?: string
  imageAlt?: string
}

const {
  url,
  title,
  headingLevel: HeadingTag = 'h3',
  footer,
  class: className,
  imageData,
  imageSrc,
  imageAlt = '',
} = Astro.props
---

<li class:list={['work-card', className]}>
  <a class="work-card-link" href={url}>
    <span class="work-media">
      {
        imageData ? (
          <Image
            src={imageData}
            alt={imageAlt}
            loading="lazy"
            decoding="async"
            widths={[370, 500, 740]}
            sizes="(max-width: 40rem) 100vw, (max-width: 64rem) 50vw, 33vw"
            format="webp"
            quality={75}
          />
        ) : imageSrc ? (
          <img src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" width="740" height="470" />
        ) : (
          <span class="work-media-fallback" aria-hidden="true" />
        )
      }
    </span>
    <span class="work-card-body">
      <HeadingTag>{title}</HeadingTag>
      <p class="work-card-description">
        <slot />
      </p>
      {footer && <p class="work-card-footer">{footer}</p>}
    </span>
    <span class="work-card-more" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 12h16"></path>
        <path d="m13 7 5 5-5 5"></path>
      </svg>
    </span>
  </a>
</li>
