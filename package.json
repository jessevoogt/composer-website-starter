{
  "name": "FirstNameLastName-com-astro",
  "description": "A personal website built with Astro, showcasing a blog and works/projects, with a focus on accessibility and responsive design.",
  "version": "4.3.0",
  "author": "Incluud",
  "license": "MIT",
  "type": "module",
  "homepage": "https://example.com/",
  "scripts": {
    "init:source": "node ./scripts/init-source.mjs",
    "init:source:reset": "node ./scripts/init-source.mjs --reset",
    "generate:data": "node ./scripts/generate-works-images.mjs && node ./scripts/generate-perusal-scores.mjs && node ./scripts/generate-page-search-index.mjs",
    "generate:demo-placeholders": "node ./scripts/generate-demo-placeholders.mjs",
    "generate:social-image": "node ./scripts/generate-social-preview-image.mjs",
    "ingest:assets": "npm run init:source && node ./scripts/ingest-assets.mjs",
    "ingest:works": "npm run init:source && node ./scripts/ingest-works.mjs",
    "ingest:works:force": "npm run init:source && node ./scripts/ingest-works.mjs --force",
    "cleanup:generated": "node ./scripts/cleanup-generated-files.mjs",
    "keystatic": "npm run init:source && node ./scripts/keystatic-server.mjs",
    "ks": "npm run keystatic",
    "dev": "npm run init:source && concurrently -c cyan,magenta -n astro,ks \"npm run ingest:assets && npm run generate:data && astro dev --open\" \"node ./scripts/keystatic-server.mjs\"",
    "dev:full": "npm run init:source && concurrently -c cyan,magenta -n astro,ks \"npm run ingest:assets && npm run ingest:works && npm run generate:data && astro dev --open\" \"node ./scripts/keystatic-server.mjs\"",
    "start": "npm run ingest:assets && npm run generate:data && astro dev",
    "lint": "npx tsc --noEmit && eslint . && npx astro check",
    "build": "npm run lint && npm run ingest:assets && npm run generate:data && npm run lint && astro build",
    "build:content": "npm run lint && npm run ingest:assets && npm run lint && astro build",
    "build:full": "npm run lint && npm run ingest:assets && npm run ingest:works && npm run generate:data && npm run lint && astro build",
    "deploy": "node ./scripts/deploy.mjs",
    "preview": "astro preview"
  },
  "keywords": [
    "astro",
    "astro-component",
    "astro-components",
    "accessible",
    "accessibility",
    "a11y",
    "wcag",
    "responsive",
    "ui-library",
    "ui-components",
    "blog",
    "works"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/incluud/accessible-astro-starter.git"
  },
  "bugs": {
    "url": "https://github.com/incluud/accessible-astro-starter/issues"
  },
  "devDependencies": {
    "@astrojs/mdx": "^4.3.9",
    "@astrojs/node": "^9.5.4",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@iconify-json/lucide": "^1.2.66",
    "@types/js-yaml": "^4.0.9",
    "@types/page-flip": "^2.0.4",
    "@types/sanitize-html": "^2.13.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "astro": "^5.17.1",
    "astro-compress": "^2.3.8",
    "astro-eslint-parser": "^1.2.2",
    "astro-icon": "^1.1.5",
    "concurrently": "^9.2.1",
    "eslint": "^9.35.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^16.4.0",
    "js-yaml": "^4.1.1",
    "pdf-to-png-converter": "^3.11.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-css-order": "^2.1.2",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.32.4",
    "ssh2-sftp-client": "^12.0.1",
    "svgo": "^4.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/markdoc": "^0.15.10",
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.6.0",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.48",
    "astro-mail-obfuscation": "^2.3.4",
    "marked": "^17.0.3",
    "page-flip": "^2.0.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "overrides": {
    "minimatch": "^10.2.2",
    "lodash": "^4.17.23"
  }
}
