---
import { getSiteConfig } from '@/utils/source-config'
import PerusalOnlyRedirect from '@components/PerusalOnlyRedirect.astro'
const isPerusalOnlyMode = getSiteConfig().perusalScoreOnlyMode
import SiteLayout from '@layouts/SiteLayout.astro'
import ContactForm from '@components/ContactForm.astro'
import { getContactPage } from '@/utils/source-config'
import { resolvePageHero } from '@/utils/page-hero'

const siteConfig = getSiteConfig()
const contactPage = getContactPage()
const { pageHero } = resolvePageHero(contactPage.preferredHeroId)

const isEmailOnlyContact = !contactPage.contactFormEnabled
const contactPageContentClass = isEmailOnlyContact
  ? 'page-content-contact page-content-contact-email-only page-content-centered'
  : 'page-content-contact page-content-centered'
---

{isPerusalOnlyMode ? (
  <PerusalOnlyRedirect />
) : (
<SiteLayout
  title={contactPage.metaTitle}
  description={contactPage.metaDescription}
  url="/contact/"
  skipTargetId="contact-heading"
  pageContentClass={contactPageContentClass}
  pageHero={pageHero}
  pageKey="contact"
>
  <section class:list={['container', 'contact-shell', isEmailOnlyContact && 'contact-shell-email-only']} id="contact" aria-labelledby="contact-heading">
    <div class:list={['contact-stage', isEmailOnlyContact && 'contact-stage-email-only']}>
      <h1 class="contact-title">{contactPage.title}</h1>
      {contactPage.introText && <p class="contact-intro-text">{contactPage.introText}</p>}

      {contactPage.contactFormEnabled ? (
        <>
          <h2 id="contact-heading" class="sr-only">Contact form</h2>
          <ContactForm idPrefix="contact" />
        </>
      ) : (
        <>
          <h2 id="contact-heading" class="sr-only">Contact details</h2>
          <p class="contact-email">
            <a href={`mailto:${siteConfig.email}`} data-obfuscation="1">{siteConfig.email}</a>
          </p>
        </>
      )}
    </div>
  </section>
</SiteLayout>
)}
