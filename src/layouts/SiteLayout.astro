                                  <span class="menu-toggle-line menu-toggle-line-bottom" />
                                </span>
                              </button>
                            </div>
                          )
                        }
                        return null
                      })}
                    </div>
                    )
                  }
                  if (isPlayerInHeaderCenter && order === 2) {
                    result.push(<div class="header-player-anchor" data-header-player-anchor style="order: 2" />)
                  }
                  return result
                })}
              </div>
            )
