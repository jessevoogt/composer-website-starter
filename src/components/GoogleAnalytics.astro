---
import { getSiteConfig } from '@/utils/source-config'

const siteConfig = getSiteConfig()
const googleAnalyticsId = siteConfig.googleAnalyticsId
---

{
  import.meta.env.PROD && googleAnalyticsId && (
    <>
      <!-- Google tag (gtag.js) -->
  <script define:vars={{ googleAnalyticsId }}>
    const GTAG = googleAnalyticsId;

    // Initialize dataLayer immediately to queue events
    window.dataLayer = window.dataLayer || [];

    // Define the gtag function - GTM script doesn't do this, we do!
    window.gtag = function(...args) {
      window.dataLayer.push(arguments);
    };

    // Initialize GA
    window.gtag('js', new Date());
    window.gtag('config', GTAG);

    // Load GTM script asynchronously
    const script = document.createElement('script');
    script.async = true;
    script.src = `https://www.googletagmanager.com/gtag/js?id=${GTAG}`;
    document.head.appendChild(script);

    // Ensure pageview is sent on every page transition
    document.addEventListener('astro:page-load', () => {
        window.gtag('config', GTAG);
    });
  </script>
    </>
  )
}