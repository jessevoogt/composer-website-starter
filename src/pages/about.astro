---
import { getSiteConfig } from '@/utils/source-config'
import PerusalOnlyRedirect from '@components/PerusalOnlyRedirect.astro'
const isPerusalOnlyMode = getSiteConfig().perusalScoreOnlyMode
import SiteLayout from '@layouts/SiteLayout.astro'
import ImmersivePageHeader from '@components/immersive/ImmersivePageHeader.astro'
import { Image } from 'astro:assets'
import { getAboutPage } from '@/utils/source-config'
import type { ImageMetadata } from 'astro'
import { marked } from 'marked'
import { buildHeroSwitcherPageData, resolvePageHero } from '@/utils/page-hero'

const aboutPage = getAboutPage()
const heroVariantEventName = 'jv:immersive:hero-variant:set'
const isDevMode = import.meta.env.DEV
const resolvedHero = resolvePageHero(aboutPage.preferredHeroId, { allowEmptyPreferredHero: true })
const pageHero = resolvedHero.pageHero
const heroSwitcherPageData = buildHeroSwitcherPageData('about', resolvedHero, isDevMode, heroVariantEventName)

// Profile image — loaded from src/assets/img/ (copied by ingest-assets from source/pages/about/)
const profileImageGlob = import.meta.glob<{ default: ImageMetadata }>('../assets/img/{profile,FirstNameLastName-profile}*.{jpg,jpeg,png,webp}')
const profileImageEntry = Object.values(profileImageGlob)[0]
const profileImage = profileImageEntry ? (await profileImageEntry()).default : null

// Parse markdown body into paragraphs while preserving inline rich text markup.
const bodyParagraphs = aboutPage.body
  .split('\n\n')
  .map((p) => p.trim())
  .filter(Boolean)
const bodyParagraphHtml = await Promise.all(
  bodyParagraphs.map(async (paragraph) => {
    const rawHtml = await marked.parseInline(paragraph)
    return rawHtml.replace(
      /<a\s+href="(https?:\/\/[^"]+)"([^>]*)>/g,
      '<a href="$1"$2 target="_blank" rel="nofollow noopener noreferrer">',
    )
  }),
)
---

{isPerusalOnlyMode ? (
  <PerusalOnlyRedirect />
) : (
<SiteLayout
  title={aboutPage.metaTitle}
  description={aboutPage.metaDescription}
  url="/about/"
  pageContentClass="page-content-about"
  pageHero={
    pageHero
      ? {
          pageKey: 'about',
          id: pageHero.id,
          src: pageHero.src,
          position: pageHero.position,
          filter: pageHero.filter,
        }
      : undefined
  }
>
  <section class="container about-section">
    <div class="about-grid">
      {profileImage && (
        <figure class="about-image">
          <Image src={profileImage} alt={aboutPage.profileImageAlt} width={920} height={1180} loading="eager" />
        </figure>
      )}

      <div class="about-copy">
        <ImmersivePageHeader title="About" class="about-copy-header" />
        <div class="about-copy-body space-content">
          {bodyParagraphHtml.map((html, index) => {
            // First paragraph gets the lede class
            const isLede = index === 0
            return isLede
              ? <p class="about-lede" set:html={html} />
              : <p set:html={html} />
          })}
        </div>
      </div>
    </div>
  </section>
  <script is:inline id="hero-switcher-page-data" type="application/json" set:html={heroSwitcherPageData} />
</SiteLayout>
)}
