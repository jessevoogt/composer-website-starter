    <script is:inline>
      // Synchronous page capture — runs during HTML parsing, before deferred module scripts.
      // Ensures the initial page (e.g. homepage) is logged even if the user navigates away
      // before module scripts execute. The module script deduplicates via URL check.
      (function () {
        try {
          console.log('[journey-inline] running on', window.location.pathname)
          var K = '_journey'
          var raw = sessionStorage.getItem(K)
          var d = raw ? JSON.parse(raw) : null
          if (!d || typeof d !== 'object' || !Array.isArray(d.pages)) {
            console.log('[journey-inline] creating fresh journey')
            d = { sessionId: crypto.randomUUID(), startedAt: new Date().toISOString(), pages: [], audioPlays: [] }
          }
          var u = window.location.pathname
          var last = d.pages[d.pages.length - 1]
          if (!last || last.url !== u) {
            console.log('[journey-inline] logging page:', u)
            d.pages.push({ url: u, title: document.title || '', ts: new Date().toISOString() })
            sessionStorage.setItem(K, JSON.stringify(d))
          } else {
            console.log('[journey-inline] dedup skip:', u)
          }
        } catch (e) { console.error('[journey-inline] error:', e) }
      })()
    </script>
    <script src="../scripts/session-journey.ts"></script>

    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        document.querySelectorAll('a[href*="/perusal-score/"]').forEach((link) => {
          link.setAttribute('data-astro-reload', '')
        })

        const skipLink = document.querySelector('.skip-link')
        if (skipLink instanceof HTMLAnchorElement && skipLink.dataset.skipBound !== 'true') {
          skipLink.dataset.skipBound = 'true'

          const onSkipClick = (event) => {
            const href = skipLink.getAttribute('href')
            if (!href || !href.startsWith('#')) return

            const target = document.querySelector(href)
            if (!(target instanceof HTMLElement)) return

            event.preventDefault()
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
            if (!target.hasAttribute('tabindex')) {
              target.setAttribute('tabindex', '-1')
            }
            focusElement(target)
            target.scrollIntoView({ block: 'start', behavior: prefersReducedMotion ? 'auto' : 'smooth' })
            history.replaceState(null, '', href)
          }

          skipLink.addEventListener('click', onSkipClick)
        }

        const contactHash = '#contact'
        const normalizePathname = (pathname) => pathname.replace(/\/+$/, '') || '/'
        const focusElement = (element) => {
          if (!(element instanceof HTMLElement)) return
          const focusWithPolicy = window.__siteFocusPolicy?.focusElement
          if (typeof focusWithPolicy === 'function') {
            focusWithPolicy(element, { preventScroll: true })
            return
          }
          element.focus({ preventScroll: true })
        }
        const focusTextInput = (element) => {
          if (!(element instanceof HTMLElement)) return
          const focusWithPolicy = window.__siteFocusPolicy?.focusTextInput
          if (typeof focusWithPolicy === 'function') {
            focusWithPolicy(element, { preventScroll: true })
            return
          }
          element.focus({ preventScroll: true })
        }
        const shouldAutoFocusTextInput = () =>
          window.__siteFocusPolicy?.canAutoFocusTextInput?.() ??
          (!window.matchMedia('(pointer: coarse)').matches && !window.matchMedia('(hover: none)').matches)
        const queueContactFocusAfterScroll = () => {
          if (!shouldAutoFocusTextInput()) return
          window.setTimeout(() => {
            const contactSection = document.querySelector(contactHash)
            if (!(contactSection instanceof HTMLElement)) return

            const firstInput = contactSection.querySelector('input, textarea, select')
            if (!(firstInput instanceof HTMLElement)) return

            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
            if (prefersReducedMotion) {
              focusTextInput(firstInput)
              return
            }

            let stableFrames = 0
            let lastX = window.scrollX
            let lastY = window.scrollY
            const stableFramesRequired = 8
            const maxWaitMs = 2400
            const startTime = performance.now()

            const waitForScrollEnd = () => {
              const deltaX = Math.abs(window.scrollX - lastX)
              const deltaY = Math.abs(window.scrollY - lastY)
              if (deltaX < 1 && deltaY < 1) {
                stableFrames += 1
              } else {
                stableFrames = 0
              }

              lastX = window.scrollX
              lastY = window.scrollY

              if (stableFrames >= stableFramesRequired || performance.now() - startTime >= maxWaitMs) {
                focusTextInput(firstInput)
                return
              }

              window.requestAnimationFrame(waitForScrollEnd)
            }

            window.requestAnimationFrame(waitForScrollEnd)
          }, 80)
        }
        const focusDedicatedContactNameField = () => {
          if (!shouldAutoFocusTextInput()) return
          if (normalizePathname(window.location.pathname) !== '/contact') return

          const nameField = document.getElementById('contact-name')
          if (!(nameField instanceof HTMLInputElement)) return
          const hasMeaningfulFocus = () => {
            const activeElement = document.activeElement
            return (
              activeElement instanceof HTMLElement &&
              activeElement !== document.body &&
              activeElement !== document.documentElement
            )
          }

          if (hasMeaningfulFocus() && document.activeElement !== nameField) return

          window.requestAnimationFrame(() => {
            window.requestAnimationFrame(() => {
              if (hasMeaningfulFocus() && document.activeElement !== nameField) return
              focusTextInput(nameField)
            })
          })
        }

        const bindContactHashFocusLinks = () => {
          const contactLinks = document.querySelectorAll('a[href*="#contact"]')
          contactLinks.forEach((link) => {
            if (!(link instanceof HTMLAnchorElement)) return
            if (link.dataset.contactFocusBound === 'true') return
            link.dataset.contactFocusBound = 'true'

            link.addEventListener('click', () => {
              let linkUrl
              try {
                linkUrl = new URL(link.href, window.location.href)
              } catch {
                return
              }

              const isSamePageLink =
                linkUrl.hash === contactHash &&
                normalizePathname(linkUrl.pathname) === normalizePathname(window.location.pathname)
              if (!isSamePageLink) return

              queueContactFocusAfterScroll()
            })
          })
        }

        bindContactHashFocusLinks()
        focusDedicatedContactNameField()

        if (window.location.hash === contactHash) {
          queueContactFocusAfterScroll()
        }
      })
    </script>


