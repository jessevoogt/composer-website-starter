---
import { getSiteConfig as _checkMode, getWorksPage } from '@/utils/source-config'
import PerusalOnlyRedirect from '@components/PerusalOnlyRedirect.astro'
const isPerusalOnlyMode = _checkMode().perusalScoreOnlyMode
import SiteLayout from '@layouts/SiteLayout.astro'
import ImmersivePageHeader from '@components/immersive/ImmersivePageHeader.astro'
import ImmersiveBadge from '@components/immersive/ImmersiveBadge.astro'
import SocialShares from '@components/SocialShares.astro'
import FormattedDate from '@components/FormattedDate.astro'
import RecordingList from '@components/RecordingList.astro'
import { getCollection, render } from 'astro:content'
import prepareWorks, { type WorkWithImage } from '@/utils/prepareWorks'
import perusalScores from '@/utils/perusal-scores'
import { slugify } from '@/utils/slugify'
import { marked } from 'marked'
import { buildHeroSwitcherPageData, resolvePageHero } from '@/utils/page-hero'

export async function getStaticPaths() {
  const works = await getCollection('works')
  const { works: preparedWorks } = prepareWorks(works)

  return preparedWorks.map((work) => {
    return {
      params: { work: work.id },
      props: { work: work },
    }
  })
}

interface Props {
  work: WorkWithImage
}

const { work } = Astro.props
const { Content } = await render(work)

const rawDescriptionHtml = await marked.parse(work.data.description)
// Add target/_blank and rel attributes to any external links produced by marked
const descriptionHtml = rawDescriptionHtml.replace(
  /<a\s+href="(https?:\/\/[^"]+)"([^>]*)>/g,
  '<a href="$1"$2 target="_blank" rel="nofollow noopener noreferrer">',
)
const descriptionMeta = work.data.description
  .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
  .replace(/[*_~`]+/g, '')
  .replace(/\n+/g, ' ')
  .trim()

function getHostName(url: string) {
  try {
    const parsedUrl = new URL(url)
    return parsedUrl.hostname.replace('www.', '')
  } catch {
    return null
  }
}
function getDefaultSheetMusicTooltip(url: string) {
  const hostName = getHostName(url)
  if (hostName) {
    return `Purchase ${work.data.title} on ${hostName}`
  }
  return `Purchase ${work.data.title}`
}
function getSheetMusicTooltip(sm: (typeof work.data.sheetMusic)[number]) {
  if (typeof sm === 'string') return getDefaultSheetMusicTooltip(sm) || sm
  return sm.tooltip || getDefaultSheetMusicTooltip(sm.url) || sm.url
}
function getSheetMusicLabel(sm: (typeof work.data.sheetMusic)[number]) {
  if (typeof sm === 'string') return getHostName(sm) || sm
  return sm.label || getHostName(sm.url) || sm.url
}
function getSheetMusicAriaLabel(sm: (typeof work.data.sheetMusic)[number]) {
  if (typeof sm === 'string') return getSheetMusicTooltip(sm)
  return sm.label || getSheetMusicTooltip(sm)
}
function getSheetMusicUrl(sm: (typeof work.data.sheetMusic)[number]) {
  if (typeof sm === 'string') {
    return sm
  } else {
    return sm.url
  }
}

const instrumentationValues = (Array.isArray(work.data.instrumentation) ? work.data.instrumentation : [work.data.instrumentation])
  .map((value) => value.trim())
  .filter(Boolean)
const tagSlugsForWork = new Set(work.tagSlugs)
const instrumentationEntries = instrumentationValues.map((label) => {
  const slug = slugify(label)
  return {
    label,
    href: tagSlugsForWork.has(slug) ? `/works/browse/${slug}/` : undefined,
  }
})
const tagEntries = work.data.tags
  .map((value) => value.trim())
  .filter(Boolean)
  .map((label) => {
    const slug = slugify(label)
    return {
      label,
      href: tagSlugsForWork.has(slug) ? `/works/browse/${slug}/` : undefined,
    }
  })
const hasPerusalScore = Boolean(work.data.hasPerusalScore && perusalScores[work.id])
const worksPage = getWorksPage()
const workLabelSingular = worksPage.workLabelSingular
const heroVariantEventName = 'jv:immersive:hero-variant:set'
const isDevMode = import.meta.env.DEV
const resolvedHero = resolvePageHero(worksPage.preferredHeroId, { allowEmptyPreferredHero: true })
const pageHero = resolvedHero.pageHero
const heroSwitcherPageData = buildHeroSwitcherPageData('works', resolvedHero, isDevMode, heroVariantEventName)
---

{isPerusalOnlyMode ? (
  <PerusalOnlyRedirect />
) : (
<SiteLayout
  title={work.data.title}
  description={descriptionMeta}
  url={`/works/${work.id}/`}
  pageContentClass="page-content-work-detail page-content-works"
  customBreadcrumbLabels={{ [work.id]: work.data.title }}
  pageHero={
    pageHero
      ? {
          pageKey: 'works',
          id: pageHero.id,
          src: pageHero.src,
          position: pageHero.position,
          filter: pageHero.filter,
        }
      : undefined
  }
>
  <ImmersivePageHeader title={work.data.title} subtitle={work.data.subtitle} subtitleClass="work-detail-subtitle" class="work-detail-page-header">
    {
      hasPerusalScore ? (
        <a href={`/works/${work.id}/perusal-score/`} data-astro-reload class="immersive-btn immersive-btn-control work-detail-score-link">
          <span class="immersive-btn-label">View Score</span>
          <span class="work-detail-score-link-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
              <ellipse cx="9" cy="17.3" rx="2.9" ry="2.35" fill="currentColor" stroke="none"></ellipse>
              <path d="M11.8 17.3V5.2"></path>
              <path d="M11.8 5.3c2.8 0.35 4.8 2.1 4.8 4.6-1.2-1.1-3-1.5-4.8-1.2"></path>
            </svg>
          </span>
        </a>
      ) : null
    }
    <div class="work-header-meta-layout">
      <div class="work-description-panel">
        <div class="work-description-text" set:html={descriptionHtml} />
      </div>
      <div class="work-meta-panel">
        <div class="work-meta-panel-scroll">
          <dl class="work-meta-grid">
            <dt>Instrumentation:</dt>
            <dd>
              {
                instrumentationEntries.map((instrument, index) => (
                  <>
                    {index > 0 ? ', ' : ''}
                    {instrument.href ? <a href={instrument.href}>{instrument.label}</a> : instrument.label}
                  </>
                ))
              }
            </dd>

            {
              work.data.duration ? (
                <>
                  <dt>Duration:</dt>
                  <dd>{work.data.duration}</dd>
                </>
              ) : null
            }
            {
              work.data.difficulty ? (
                <>
                  <dt>Difficulty:</dt>
                  <dd>{work.data.difficulty}</dd>
                </>
              ) : null
            }
            {
              work.data.completionDate ? (
                <>
                  <dt>Completion date:</dt>
                  <dd>
                    <FormattedDate date={work.data.completionDate} />
                  </dd>
                </>
              ) : null
            }
            {
              work.data.sheetMusic.length ? (
                <>
                  <dt>Sheet Music:</dt>
                  <dd style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                    {work.data.sheetMusic.map((sm) => (
                      <a
                        href={getSheetMusicUrl(sm)}
                        target="_blank"
                        rel="noreferrer noopener"
                        title={getSheetMusicTooltip(sm)}
                        aria-label={getSheetMusicAriaLabel(sm)}
                      >
                        {getSheetMusicLabel(sm)}
                      </a>
                    ))}
                  </dd>
                </>
              ) : null
            }
            {
              tagEntries.length ? (
                <>
                  <dt>Tags:</dt>
                  <dd>
                    <ul class="tags-list">
                      {tagEntries.map((tag) => (
                        <li>{tag.href ? <ImmersiveBadge href={tag.href}>{tag.label}</ImmersiveBadge> : <ImmersiveBadge>{tag.label}</ImmersiveBadge>}</li>
                      ))}
                    </ul>
                  </dd>
                </>
              ) : null
            }
          </dl>
        </div>
      </div>
    </div>
    {work.data.recordings ? (
      <div class="work-detail-recordings-row">
        <RecordingList
          recordings={work.data.recordings}
          workId={work.id}
          workTitle={work.data.title}
          composer={work.data.composer}
          thumbnail={work.data.thumbnail}
          singleLinkHeadingLevel="h2"
          creditTagLinks={work.creditTagLinks}
        />
      </div>
    ) : null}
  </ImmersivePageHeader>
  <section class="work-detail-content-section">
    <div class="narrow space-content container">
      <Content />
    </div>
  </section>
  <section class="work-detail-share-section">
    <div class="narrow space-content container">
      <h2>Share this {workLabelSingular}</h2>
      <p>Like this {workLabelSingular}? Share it with your network!</p>
      <SocialShares />
    </div>
  </section>
  <script is:inline id="hero-switcher-page-data" type="application/json" set:html={heroSwitcherPageData} />
</SiteLayout>
)}

<style is:global>
  .page-content-work-detail {
    padding-bottom: 0;
  }

  .work-detail-content-section {
    margin-block: var(--space-xl);
  }

  .work-detail-share-section {
    margin-top: var(--space-xl);
    margin-bottom: 0;
    background: color-mix(in srgb, var(--bg-soft) 86%, var(--surface) 14%);
    padding-block: clamp(1.75rem, 4vw, 2.75rem);
  }

  .work-detail-page-header .page-header-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: start;
    column-gap: var(--space-s);
    row-gap: 0.15rem;
  }

  .work-detail-page-header .page-header-inner > h1 {
    flex: 1 1 18rem;
    min-width: 0;
    margin-bottom: 0;
  }

  .work-detail-page-header .page-header-inner > .page-header-subtitle {
    order: 2;
    flex: 1 1 100%;
    margin-top: 0.5rem;
  }

  .page-header-subtitle.work-detail-subtitle {
    max-width: 72ch;
    color: var(--ink);
    font-size: var(--font-size-1);
    font-weight: 600;
    line-height: 1.3;
  }

  .work-detail-score-link {
    order: 1;
    flex: 0 0 auto;
    display: inline-flex;
    gap: 0.42rem;
    align-self: flex-start;
    margin-left: auto;
    margin-top: 0.18rem;
    white-space: nowrap;
    --work-score-icon-accent: color-mix(in srgb, var(--focus-ring-color) 72%, var(--ink) 28%);
    --work-score-icon-accent-active: color-mix(in srgb, var(--focus-ring-color) 88%, #fff 12%);
  }

  .work-detail-score-link-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5em;
    height: 1.5em;
    min-width: 1.5em;
    flex: 0 0 auto;
    color: var(--work-score-icon-accent);
    opacity: 0.98;
    transform-origin: center;
    transition: color 180ms ease;
  }

  .work-detail-score-link-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .work-detail-score-link:hover .work-detail-score-link-icon,
  .work-detail-score-link:focus-visible .work-detail-score-link-icon {
    color: var(--work-score-icon-accent-active);
  }

  .work-header-meta-layout {
    order: 3;
    flex: 1 1 100%;
    min-width: 0;
    margin-top: var(--space-s);
    display: grid;
    gap: var(--space-s);
  }

  .work-detail-recordings-row {
    order: 4;
    flex: 1 1 100%;
    min-width: 0;
  }

  .work-description-text {
    max-width: 68ch;
    color: var(--ink-soft);
    font-size: var(--font-size-0);
    line-height: 1.5;
  }

  .work-description-text p {
    margin: 0;
  }

  .work-description-text p + p {
    margin-top: 0.75em;
  }

  .work-meta-grid {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.2em 1.5em;
    align-items: start;
    font-size: var(--font-size--1);
    margin: 0;
  }

  .work-meta-grid dt {
    font-weight: 600;
    color: var(--ink);
  }

  .work-meta-grid dd {
    color: var(--ink-soft);
    margin: 0;
  }

  @media (min-width: 64rem), (min-width: 48rem) and (orientation: landscape) {
    .work-detail-score-link {
      padding: 0.58rem 0.92rem;
      font: 600 0.95rem/1 var(--font-heading);
      letter-spacing: 0.085em;
    }

    .work-header-meta-layout {
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
      align-items: start;
      gap: var(--space-s);
    }

    .work-meta-panel {
      border: 1px solid var(--line);
      border-color: color-mix(in srgb, var(--line) 62%, transparent);
      background: var(--bg-soft);
      background: color-mix(in srgb, var(--bg) 72%, var(--surface) 28%);
      padding: var(--space-s);
    }

    .work-description-panel {
      max-height: 33vh;
      overflow-y: auto;
    }

    .work-meta-panel-scroll {
      max-height: 33vh;
      overflow-y: auto;
    }

    .work-meta-grid {
      max-height: 33vh;
      overflow-y: auto;
      font-size: var(--font-size--2);
    }
  }

  /* Remove the extra top margin applied by .space-content > dl > * + *
     for this dl so grid gap controls row spacing and alignment */
  .space-content > dl.work-meta-grid > * + * {
    margin-block-start: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .work-detail-score-link:hover .work-detail-score-link-icon,
    .work-detail-score-link:focus-visible .work-detail-score-link-icon {
      animation: work-detail-score-icon-bump 240ms ease-out;
    }
  }

  @keyframes work-detail-score-icon-bump {
    0% {
      transform: translateY(0) scale(1);
    }

    45% {
      transform: translateY(-0.12rem) scale(1.08);
    }

    100% {
      transform: translateY(0) scale(1);
    }
  }

  @media (max-width: 36rem) {
    .work-detail-page-header .page-header-inner {
      row-gap: 0.65rem;
    }

    .work-detail-page-header .page-header-inner > h1 {
      flex-basis: 100%;
    }

    .work-detail-page-header .page-header-inner > .page-header-subtitle {
      order: 2;
      margin-top: 0;
    }

    .work-detail-score-link {
      order: 3;
      align-self: flex-start;
      margin-left: 0;
      margin-top: 0;
    }

    .work-header-meta-layout {
      order: 4;
    }

    .work-detail-recordings-row {
      order: 5;
    }
  }
</style>
