---
import { Image } from 'astro:assets'

/**
 * BreakoutImage Component
 *
 * @description A component for displaying a landscape image that breaks out of the container
 */
interface Props {
  /**
   * The image source
   */
  src: string
  /**
   * The image alt text
   */
  alt: string
}

const { src, alt = '' } = Astro.props
---

<div class="breakout-image">
  <Image src={src} alt={alt} width={1400} height={700} loading="lazy" />
  <div class="breakout-image-overlay"></div>
</div>

<style>
  .breakout-image {
    position: relative;
    margin-inline: -1rem;
    margin-block: var(--space-m);
  }

  @media (min-width: 48rem) {
    .breakout-image {
      margin-inline: -2rem;
    }
  }

  @media (min-width: 64rem) {
    .breakout-image {
      margin-inline: -7.5rem;
    }
  }

  .breakout-image :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    object-fit: cover;
  }

  .breakout-image-overlay {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-md);
    box-shadow: inset 0 2px 6px rgba(0, 0, 0, 0.3);
  }
</style>
