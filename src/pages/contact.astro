---
import { getSiteConfig } from '@/utils/source-config'
import PerusalOnlyRedirect from '@components/PerusalOnlyRedirect.astro'
const isPerusalOnlyMode = getSiteConfig().perusalScoreOnlyMode
import SiteLayout from '@layouts/SiteLayout.astro'
import ImmersivePageHeader from '@components/immersive/ImmersivePageHeader.astro'
import ContactForm from '@components/ContactForm.astro'
import { getContactPage } from '@/utils/source-config'
import { buildHeroSwitcherPageData, resolvePageHero } from '@/utils/page-hero'

const siteConfig = getSiteConfig()
const contactPage = getContactPage()
const heroVariantEventName = 'jv:immersive:hero-variant:set'
const isDevMode = import.meta.env.DEV
const resolvedHero = resolvePageHero(contactPage.preferredHeroId, { allowEmptyPreferredHero: true })
const pageHero = resolvedHero.pageHero
const heroSwitcherPageData = buildHeroSwitcherPageData('contact', resolvedHero, isDevMode, heroVariantEventName)
---

{isPerusalOnlyMode ? (
  <PerusalOnlyRedirect />
) : (
<SiteLayout
  title={contactPage.metaTitle}
  description={contactPage.metaDescription}
  url="/contact/"
  skipTargetId="contact-heading"
  pageContentClass="page-content-contact"
  pageHero={
    pageHero
      ? {
          pageKey: 'contact',
          id: pageHero.id,
          src: pageHero.src,
          position: pageHero.position,
          filter: pageHero.filter,
        }
      : undefined
  }
>
  <section class="container contact-shell" id="contact" aria-labelledby="contact-heading">
    <div class="contact-stage">
      <ImmersivePageHeader title={contactPage.title} subtitle={contactPage.introText} class="contact-stage-header">
        {contactPage.contactFormEnabled ? (
          <>
            <h2 id="contact-heading" class="sr-only">Contact form</h2>
            <ContactForm
              idPrefix="contact"
              nameLabel={contactPage.contactFormNameLabel}
              namePlaceholder={contactPage.contactFormNamePlaceholder}
              emailLabel={contactPage.contactFormEmailLabel}
              emailPlaceholder={contactPage.contactFormEmailPlaceholder}
              messageLabel={contactPage.contactFormMessageLabel}
              messagePlaceholder={contactPage.contactFormMessagePlaceholder}
              submitText={contactPage.contactFormSubmitText}
            />
          </>
        ) : (
          <>
            <h2 id="contact-heading" class="sr-only">Contact details</h2>
            {contactPage.contactEmailLeadText ? <p>{contactPage.contactEmailLeadText}</p> : null}
            <p class="contact-email">
              <a href={`mailto:${siteConfig.email}`} data-obfuscation="1">
                {contactPage.contactEmailLinkText || siteConfig.email}
              </a>
            </p>
          </>
        )}
      </ImmersivePageHeader>
    </div>
  </section>

  <script is:inline id="hero-switcher-page-data" type="application/json" set:html={heroSwitcherPageData} />
</SiteLayout>
)}
