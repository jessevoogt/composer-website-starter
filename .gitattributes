# Normalize line endings across platforms
* text=auto

# Source files — always LF
*.mjs text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.astro text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Binary files — no conversion
*.jpg binary
*.jpeg binary
*.png binary
*.webp binary
*.avif binary
*.gif binary
*.ico binary
*.mp3 binary
*.wav binary
*.aiff binary
*.flac binary
*.pdf binary
*.woff binary
*.woff2 binary
