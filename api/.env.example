# ─── SendGrid ──────────────────────────────────────────────────────────
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Site ──────────────────────────────────────────────────────────────
# Frontend Astro site URL (used to build magic links)
FRONTEND_URL="https://jessevoogt.com"

# Composer name (used in email templates)
COMPOSER_NAME="Jesse Voogt"

# "From" email address — must match a verified SendGrid sender identity
FROM_EMAIL="music@jessevoogt.com"

# Where contact form messages are delivered (also receives perusal score request notifications)
CONTACT_RECIPIENT="music@jessevoogt.com"

# ─── Security ──────────────────────────────────────────────────────────
# Shared HMAC secret for signing perusal access tokens.
# Must match tokenSecret in source/site/perusal-access.yaml.
# Leave empty to use the insecure default dev key.
HMAC_SECRET=""

# Token expiration in days (should match frontend tokenExpirationDays)
TOKEN_EXP_DAYS=90

# Comma-separated allowed origins for CORS (include localhost for dev)
ALLOWED_ORIGINS="https://jessevoogt.com,http://localhost:4321,http://localhost:4323"

# ─── Routing ─────────────────────────────────────────────────────────
# Base path prefix to strip from incoming request URIs.
# Set this when the API lives in a subdirectory (e.g. /api).
BASE_PATH="/api"

# ─── PDF Downloads ───────────────────────────────────────────────────
# Absolute path to the private scores directory on the server.
# On Cloudways: /home/master/applications/<app-id>/private_html/scores
PRIVATE_SCORES_PATH=""

# ─── Rate Limiting ────────────────────────────────────────────────────
# Max perusal access requests per email per hour
RATE_LIMIT_PERUSAL=5

# Max contact form submissions per email per hour
RATE_LIMIT_CONTACT=3

# Max PDF downloads per token/work per hour
RATE_LIMIT_DOWNLOAD=20
